// 数据模型 - 与服务器通信的协议

package com.luoking.agent.models

import kotlinx.serialization.Serializable

// ── 客户端 → 服务器 ──

@Serializable
data class Heartbeat(
    val type: String = "heartbeat",
    val device_id: String,
    val phase: String = "unknown",
    val battery: Int = 0
)

@Serializable
data class ScreenshotUpload(
    val type: String = "upload",
    val device_id: String,
    val image: String  // JPEG Base64
)

@Serializable
data class ActionResult(
    val type: String = "action_result",
    val device_id: String,
    val success: Boolean
)

// ── 服务器 → 客户端 ──

@Serializable
data class HeartbeatAck(
    val type: String = "heartbeat_ack",
    val server_time: Long = 0,
    val session_id: String = ""
)

@Serializable
data class ServerAction(
    val type: String = "action",
    val action_type: String = "wait",  // "skill" | "swap" | "tap" | "wait" | "back"
    val skill_index: Int? = null,
    val swap_index: Int? = null,
    val coordinate: List<Int>? = null,  // [x, y]
    val delay_ms: Int = 500,
    val reasoning: String = "",
    val confidence: Double = 0.0
)

@Serializable
data class ServerError(
    val type: String = "error",
    val message: String = ""
)