@dataclass
class SkillUsageRecord:
    """技能使用记录"""
    pet_name: str
    skill_name: str
    turn_number: int
    target: str = ""           # 目标
    effectiveness: str = ""    # 效果描述
    damage: int = 0            # 造成的伤害


@dataclass
class TurnMemory:
    """单回合记忆"""
    turn_number: int
    my_action: Optional[str] = None
    enemy_action: Optional[str] = None
    my_hp_change: int = 0
    enemy_hp_change: int = 0
    weather: str = "none"
    notes: str = ""


@dataclass
class BattleMemory:
    """
    战斗记忆 - 跨回合的信息聚合。
    
    保存的信息：
    - 敌方技能使用历史（用于推算PP）
    - 换宠历史
    - 天气变化
    - 异常状态变化
    - 能力等级变化
    - 伤害数值
    """
    battle_id: str = ""
    turn_number: int = 0
    
    # 敌方技能使用记录
    enemy_skill_history: List[SkillUsageRecord] = field(default_factory=list)
    # 敌方技能PP估算 {技能名: 剩余PP}
    enemy_pp_estimate: Dict[str, int] = field(default_factory=dict)
    enemy_pp_max: Dict[str, int] = field(default_factory=dict)
    # 敌方换宠历史
    enemy_switch_history: List[Tuple[int, str, str]] = field(default_factory=list)
    # 回合记录
    turn_history: List[TurnMemory] = field(default_factory=list)
    
    # 天气历史
    weather_history: List[Tuple[int, str]] = field(default_factory=list)
    # 异常状态历史
    status_history: Dict[str, List[Tuple[int, str]]] = field(default_factory=dict)
    # 能力等级变化历史
    boost_history: Dict[str, List[Tuple[int, str, int]]] = field(default_factory=dict)
    
    # 敌方宠物阵容
    enemy_roster: List[str] = field(default_factory=list)
    # 敌方当前宠物
    enemy_current_pet: str = ""
    
    def record_enemy_skill(self, pet_name: str, skill_name: str, turn: int):
        """记录敌方使用的技能"""
        self.enemy_skill_history.append(SkillUsageRecord(
            pet_name=pet_name, skill_name=skill_name, turn_number=turn
        ))
        # 估算PP减少
        if skill_name in self.enemy_pp_estimate:
            self.enemy_pp_estimate[skill_name] = max(0, self.enemy_pp_estimate[skill_name] - 1)
        else:
            # 首次出现，假设初始PP为最大值（常见技能PP范围5-20）
            self.enemy_pp_estimate[skill_name] = 4  # 默认剩余
            self.enemy_pp_max[skill_name] = 10
    
    def record_enemy_switch(self, turn: int, from_pet: str, to_pet: str):
        """记录敌方换宠"""
        self.enemy_switch_history.append((turn, from_pet, to_pet))
        self.enemy_current_pet = to_pet
        if to_pet not in self.enemy_roster:
            self.enemy_roster.append(to_pet)
    
    def record_my_action(self, turn: int, action: str):
        """记录我方行动"""
        while len(self.turn_history) < turn:
            self.turn_history.append(TurnMemory(turn_number=len(self.turn_history) + 1))
        if turn <= len(self.turn_history):
            self.turn_history[turn - 1].my_action = action
    
    def record_enemy_action(self, turn: int, action: str):
        """记录敌方行动"""
        while len(self.turn_history) < turn:
            self.turn_history.append(TurnMemory(turn_number=len(self.turn_history) + 1))
        if turn <= len(self.turn_history):
            self.turn_history[turn - 1].enemy_action = action
    
    def get_enemy_pp_summary(self) -> str:
        """获取敌方PP估算摘要"""
        if not self.enemy_pp_estimate:
            return ""
        parts = []
        for skill, pp in sorted(self.enemy_pp_estimate.items(), key=lambda x: x[1]):
            max_pp = self.enemy_pp_max.get(skill, 10)
            parts.append(f"{skill} PP≈{pp}/{max_pp}")
        return "敌方PP估算: " + ", ".join(parts)
    
    def get_enemy_history_summary(self) -> str:
        """获取敌方行动历史摘要"""
        if not self.enemy_skill_history:
            return ""
        # 只返回最近5个动作
        recent = self.enemy_skill_history[-5:]
        parts = []
        for r in recent:
            parts.append(f"第{r.turn_number}回合: {r.pet_name} 使用了 {r.skill_name}")
        return "敌方最近行动:\n" + "\n".join(parts)
    
    def get_full_context(self) -> str:
        """获取完整记忆上下文"""
        parts = []
        parts.append(f"战斗进行到第 {self.turn_number} 回合")
        
        enemy_pp = self.get_enemy_pp_summary()
        if enemy_pp:
            parts.append(enemy_pp)
        
        enemy_history = self.get_enemy_history_summary()
        if enemy_history:
            parts.append(enemy_history)
        
        if self.enemy_roster:
            parts.append(f"敌方阵容: {', '.join(self.enemy_roster)}")
        
        if self.weather_history:
            parts.append(f"天气变化: {', '.join(f'第{t}回合:{w}' for t,w in self.weather_history[-3:])}")
        
        return "\n".join(parts)
    
    def update_from_battle_state(self, state: BattleState):
        """从当前战斗状态更新记忆"""
        self.turn_number = state.turn_number
        
        # 更新敌方宠物
        if state.enemy_pet and state.enemy_pet.name:
            if state.enemy_pet.name != self.enemy_current_pet and self.enemy_current_pet:
                self.record_enemy_switch(
                    state.turn_number,
                    self.enemy_current_pet,
                    state.enemy_pet.name
                )
            self.enemy_current_pet = state.enemy_pet.name
            if state.enemy_pet.name not in self.enemy_roster:
                self.enemy_roster.append(state.enemy_pet.name)
        
        # 更新天气
        if state.weather.value != "none":
            if not self.weather_history or self.weather_history[-1][1] != state.weather.value:
                self.weather_history.append((state.turn_number, state.weather.value))


class BattleMemoryManager:
    """
    战斗记忆管理器。
    负责记忆的持久化、加载、查询。
    """
    
    def __init__(self, data_dir: str = "data/memory"):
        self.data_dir = data_dir
        self.current_memory: Optional[BattleMemory] = None
        os.makedirs(data_dir, exist_ok=True)
    
    def new_battle(self, battle_id: str) -> BattleMemory:
        """开始新战斗的记忆"""
        self.current_memory = BattleMemory(battle_id=battle_id)
        return self.current_memory
    
    def save(self):
        """保存当前战斗记忆"""
        if not self.current_memory:
            return
        path = f"{self.data_dir}/{self.current_memory.battle_id}.json"
        with open(path, "w") as f:
            json.dump(asdict(self.current_memory), f, ensure_ascii=False, indent=2)
    
    def load(self, battle_id: str) -> Optional[BattleMemory]:
        """加载战斗记忆"""
        path = f"{self.data_dir}/{battle_id}.json"
        if os.path.exists(path):
            with open(path) as f:
                data = json.load(f)
                return BattleMemory(**data)
        return None
    
    def clear(self):
        """清除当前记忆"""
        self.current_memory = None