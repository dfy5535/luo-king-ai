"""
luo_king_agent/agents/rule_agent.py
=====================================
Operator的要求：
  "规则Agent：只负责'是否合法？'"
  "PP有没有？技能是不是封印？是不是已经死亡？是不是不能换宠？"

这个Agent负责所有合法性检查。
不需要AI，纯规则引擎。
"""

from __future__ import annotations
from typing import List, Optional, Dict, Any
import logging

from ..core.models import (
    BattleState, BattleAction, BattleActionType,
    PetState, SkillState, StatusCondition
)

logger = logging.getLogger(__name__)


class RuleAgent:
    """
    规则Agent。
    
    职责：检查一个动作是否合法。
    
    不需要AI，全部是确定的规则。
    - PP是否足够
    - 技能是否被封印
    - 宠物是否存活
    - 换宠是否允许
    """
    
    def __init__(self):
        self.rules: List[Rule] = self._load_rules()
    
    def _load_rules(self) -> List[Rule]:
        return [
            Rule("PP充足", self._check_pp),
            Rule("技能未封印", self._check_sealed),
            Rule("宠物存活", self._check_alive),
            Rule("换宠允许", self._check_swap_allowed),
            Rule("非睡眠状态可用技能", self._check_status_blocks_action),
        ]
    
    def validate(self, action: BattleAction, state: BattleState) -> ValidationResult:
        """
        验证动作是否合法。
        
        Returns:
            ValidationResult: 包含是否合法、违法原因、修正建议
        """
        violations = []
        for rule in self.rules:
            if not rule.check(action, state):
                violations.append(rule.name)
        
        if not violations:
            return ValidationResult(valid=True)
        
        return ValidationResult(
            valid=False,
            violations=violations,
            suggestion=self._suggest_fix(action, violations, state)
        )
    
    def validate_all_actions(self, state: BattleState) -> List[BattleAction]:
        """返回所有合法动作列表"""
        valid_actions = []
        
        if state.my_active:
            for skill in state.my_active.skills:
                action = BattleAction(
                    action_type=BattleActionType.技能,
                    target=skill.name
                )
                result = self.validate(action, state)
                if result.valid:
                    valid_actions.append(action)
        
        for pet in state.my_pets:
            if pet != state.my_active and pet.is_alive:
                action = BattleAction(
                    action_type=BattleActionType.换宠,
                    target=pet.name
                )
                result = self.validate(action, state)
                if result.valid:
                    valid_actions.append(action)
        
        return valid_actions
    
    def _check_pp(self, action: BattleAction, state: BattleState) -> bool:
        """检查PP是否充足"""
        if action.action_type != BattleActionType.技能 or not state.my_active:
            return True
        for skill in state.my_active.skills:
            if skill.name == action.target:
                return skill.pp_current > 0
        return False
    
    def _check_sealed(self, action: BattleAction, state: BattleState) -> bool:
        """检查技能是否被封印"""
        if action.action_type != BattleActionType.技能 or not state.my_active:
            return True
        for skill in state.my_active.skills:
            if skill.name == action.target:
                return not skill.is_sealed
        return False
    
    def _check_alive(self, action: BattleAction, state: BattleState) -> bool:
        """检查宠物是否存活"""
        if action.action_type == BattleActionType.换宠:
            for pet in state.my_pets:
                if pet.name == action.target:
                    return pet.is_alive
        return True
    
    def _check_swap_allowed(self, action: BattleAction, state: BattleState) -> bool:
        """检查换宠是否允许（一回合一次）"""
        if action.action_type == BattleActionType.换宠:
            # 检查是否已经换过宠
            if state.my_last_action and state.my_last_action.action_type == BattleActionType.换宠:
                return False
        return True
    
    def _check_status_blocks_action(self, action: BattleAction, state: BattleState) -> bool:
        """检查异常状态是否阻止行动"""
        if not state.my_active:
            return True
        if state.my_active.status == StatusCondition.睡眠:
            return action.action_type == BattleActionType.等待
        if state.my_active.status == StatusCondition.冰冻:
            return action.action_type == BattleActionType.等待
        return True
    
    def _suggest_fix(self, action: BattleAction, violations: List[str], state: BattleState) -> str:
        """给出修正建议"""
        if "PP充足" in violations:
            return f"{action.target} PP不足，请选择其他技能"
        if "技能未封印" in violations:
            return f"{action.target} 被封印，无法使用"
        if "宠物存活" in violations:
            return f"{action.target} 已阵亡，选择其他宠物"
        if "非睡眠状态可用技能" in violations:
            return f"{state.my_active.name} 处于{state.my_active.status.value}状态，无法行动"
        return "动作不合法，请重新选择"


@dataclass
class Rule:
    name: str
    check_func: callable
    
    def check(self, action: BattleAction, state: BattleState) -> bool:
        return self.check_func(action, state)


@dataclass
class ValidationResult:
    valid: bool
    violations: List[str] = field(default_factory=list)
    suggestion: str = ""


from dataclasses import dataclass, field