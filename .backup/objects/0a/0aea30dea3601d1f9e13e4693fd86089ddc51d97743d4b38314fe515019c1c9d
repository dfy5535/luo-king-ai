"""
luo_king_agent/orchestrator.py
================================
最终数据流：
ADB截图 → SenseNova(多模态视觉) → BattleState → Memory → Battle Engine → Strategy Agent → Rule Agent → Executor

Operator的要求：
  "Rule Agent应该最后执行。不要在Strategy之前。"
  "LLM说使用技能4，Rule发现技能4 PP=0，非法，自动改成技能1。"
  "不会因为LLM犯错导致挂机。"
"""

from __future__ import annotations
from typing import Optional, Dict, Any
import logging
import time
import uuid
import os

from .core.models import (
    BattleState, BattleAction, BattleActionType, GamePhase
)
from .vision.llm_parser import LLMVisionParser
from .engine.battle_engine import BattleEngine, PetDatabase, BattleRecommendation
from .engine.battle_memory import BattleMemory, BattleMemoryManager
from .agents.rule_agent import RuleAgent
from .agents.strategy_agent import StrategyAgent
from .executor.executor import Executor, ADBController
from .state_machine.game_state_machine import GameStateMachine
from .learning.replay_analyzer import ReplayAnalyzer, BattleRecord

logger = logging.getLogger(__name__)


class GameAgent:
    """
    游戏智能体 - 核心控制器。
    
    数据流：
    ADB截图 → SenseNova视觉 → BattleState → Memory → Battle Engine
      → Strategy Agent → Rule Agent → Executor
    
    关键设计：
    - Rule Agent在最后：LLM的决策必须经过合法性验证
    - Memory层维护跨回合信息：敌方PP、技能历史、换宠记录
    - 状态机控制流程：非战斗阶段不需要AI
    """
    
    def __init__(self, config: Optional[Dict] = None):
        self.config = config or {}
        
        # 初始化所有模块
        self.state_machine = GameStateMachine()
        self.vision_parser = LLMVisionParser(
            llm_client=self.config.get("llm_client"),
            model=self.config.get("vision_model", "sensenova-6.7-flash-lite")
        )
        self.battle_engine = BattleEngine()
        self.rule_agent = RuleAgent()
        self.strategy_agent = StrategyAgent(
            llm_client=self.config.get("strategy_llm_client"),
            model=self.config.get("strategy_model", "gemini-2.5-flash")
        )
        self.executor = Executor(
            backend=self.config.get("backend", "adb"),
            device_id=self.config.get("device_id"),
        )
        self.adb = ADBController(
            device_id=self.config.get("device_id"),
            host=self.config.get("device_host"),
        )
        self.replay_analyzer = ReplayAnalyzer(
            data_dir=self.config.get("data_dir", "data/battles")
        )
        self.memory_manager = BattleMemoryManager(
            data_dir=self.config.get("memory_dir", "data/memory")
        )
        
        # 运行状态
        self.running = False
        self.current_battle_id: Optional[str] = None
        self.battle_start_time: float = 0.0
        self.loop_count = 0
        
    # ──────────────────────────────────────────────────────────────
    # 生命周期
    # ──────────────────────────────────────────────────────────────
    
    def connect_device(self, backend: str = "adb", host: Optional[str] = None):
        """连接设备"""
        logger.info(f"连接设备: backend={backend}, host={host}")
        if host:
            self.adb.host = host
            self.executor.host = host
        self.adb.connect()
        logger.info(f"设备连接状态: {self.adb.is_connected()}")
    
    def start(self):
        """启动主循环"""
        self.running = True
        logger.info("=" * 50)
        logger.info("智能体启动")
        logger.info("=" * 50)
        
        try:
            while self.running:
                self._main_loop_iteration()
                self.loop_count += 1
        except KeyboardInterrupt:
            logger.info("用户中断")
        finally:
            self.stop()
    
    def stop(self):
        """停止运行"""
        self.running = False
        logger.info("智能体停止")
    
    # ──────────────────────────────────────────────────────────────
    # 主循环
    # ──────────────────────────────────────────────────────────────
    
    def _main_loop_iteration(self):
        """
        主循环单次迭代。
        
        完整数据流：
        1. ADB截图
        2. SenseNova多模态视觉解析 → BattleState
        3. 更新Memory
        4. 状态机更新
        5. 如果需要AI：
           a. Battle Engine分析
           b. Strategy Agent博弈决策
           c. Rule Agent合法性验证（最后一道防线！）
           d. 执行器执行
        6. 否则：程序写死的流程控制
        """
        # 1. 截图
        screenshot_path = f"/tmp/battle_screen_{int(time.time())}.png"
        image = self.executor.screenshot(screenshot_path)
        if not image:
            logger.warning("截图失败，重试...")
            time.sleep(1)
            return
        
        # 2. 视觉解析（SenseNova多模态）
        battle_state = self.vision_parser.parse_screenshot(screenshot_path)
        logger.debug(f"视觉解析置信度: {battle_state.parse_confidence:.2f}")
        
        # 3. 更新Memory
        self._update_memory(battle_state)
        
        # 4. 状态机更新
        self.state_machine.battle_state = battle_state
        self._update_phase(battle_state)
        
        # 5. 阶段处理
        phase = self.state_machine.current_phase
        
        if phase == GamePhase.战斗 and battle_state.is_my_turn:
            self._handle_battle_turn(battle_state)
        elif phase == GamePhase.战斗:
            logger.debug("等待敌方回合...")
            time.sleep(1.5)
        else:
            self._handle_non_battle_phase(phase)
    
    def _update_memory(self, state: BattleState):
        """更新战斗记忆"""
        if not self.memory_manager.current_memory:
            return
        memory = self.memory_manager.current_memory
        memory.update_from_battle_state(state)
        
        # 如果上一回合我方有行动，记录
        if state.my_last_action:
            memory.record_my_action(state.turn_number, 
                f"{state.my_last_action.action_type.value}:{state.my_last_action.target}")
    
    # ──────────────────────────────────────────────────────────────
    # 战斗回合处理（核心数据流）
    # ──────────────────────────────────────────────────────────────
    
    def _handle_battle_turn(self, state: BattleState):
        """
        处理一个战斗回合。
        
        数据流：
        BattleState → Battle Engine → Strategy Agent → Rule Agent → Executor
        
        Rule Agent是最后一道防线！
        """
        logger.info(f"===== 回合 {state.turn_number} =====")
        
        # 1. Battle Engine分析
        self.battle_engine.update_state(state)
        recommendation = self.battle_engine.analyze()
        
        # 2. 获取Memory上下文
        memory_context = ""
        if self.memory_manager.current_memory:
            memory_context = self.memory_manager.current_memory.get_full_context()
        
        # 3. Strategy Agent博弈决策
        action = self.strategy_agent.decide(state, recommendation, memory_context)
        logger.info(f"策略决策: {action.action_type.value} → {action.target} ({action.reasoning})")
        
        # 4. Rule Agent合法性验证（最后一道防线！）
        validation = self.rule_agent.validate(action, state)
        if not validation.valid:
            logger.warning(f"规则验证失败: {validation.violations}")
            logger.warning(f"修正建议: {validation.suggestion}")
            
            # 寻找合法动作中引擎评分最高的
            valid_actions = self.rule_agent.validate_all_actions(state)
            if valid_actions and recommendation.skill_scores:
                # 从合法动作中找引擎评分最高的
                best_valid = None
                best_score = -1
                for va in valid_actions:
                    if va.action_type == BattleActionType.技能:
                        for s in recommendation.skill_scores:
                            if s.skill_name == va.target and s.score > best_score:
                                best_score = s.score
                                best_valid = va
                if best_valid:
                    action = best_valid
                    action.reasoning = f"规则修正: {validation.suggestion}"
                    logger.info(f"修正后动作: {action.target}")
                else:
                    action = valid_actions[0] if valid_actions else BattleAction(
                        BattleActionType.等待, reasoning="无合法动作"
                    )
        
        # 5. 记录记忆
        if self.memory_manager.current_memory:
            self.memory_manager.current_memory.record_my_action(
                state.turn_number,
                f"{action.action_type.value}:{action.target}"
            )
        
        # 6. 执行
        success = self.executor.execute(action, state)
        if success:
            self.executor.wait_for_animation(1.0)
            state.my_last_action = action
            self.state_machine.battle_state = state
            self.memory_manager.save()
        else:
            logger.error("执行失败")
    
    def _handle_non_battle_phase(self, phase: GamePhase):
        """处理非战斗阶段"""
        phase_actions = {
            GamePhase.登录: self._auto_login,
            GamePhase.大厅: self._auto_start_match,
            GamePhase.匹配中: self._wait_for_match,
            GamePhase.选宠: self._auto_select_pets,
            GamePhase.结算: self._auto_handle_result,
        }
        handler = phase_actions.get(phase)
        if handler:
            handler()
        else:
            time.sleep(1)
    
    def _auto_login(self):
        logger.info("自动登录...")
        self.executor._tap((960, 600))
        time.sleep(3)
    
    def _auto_start_match(self):
        logger.info("自动开始匹配...")
        coords = self.executor._get_coords("开始匹配")
        self.executor._tap(coords)
        self.state_machine.transition_to(GamePhase.匹配中)
        time.sleep(2)
    
    def _wait_for_match(self):
        time.sleep(2)
    
    def _auto_select_pets(self):
        logger.info("自动选宠...")
        self.executor._tap((960, 800))
        self.executor._tap((960, 950))
        time.sleep(2)
    
    def _auto_handle_result(self):
        logger.info("战斗结算处理...")
        self.executor._tap((960, 900))
        time.sleep(3)
        self.state_machine.transition_to(GamePhase.大厅)
    
    # ──────────────────────────────────────────────────────────────
    # 阶段与战斗结束处理
    # ──────────────────────────────────────────────────────────────
    
    def _update_phase(self, state: BattleState):
        """根据视觉解析结果更新状态机"""
        target_phase = state.phase
        if target_phase != self.state_machine.current_phase:
            self.state_machine.transition_to(target_phase)
            
            if target_phase == GamePhase.战斗:
                self.current_battle_id = f"battle_{int(time.time())}_{uuid.uuid4().hex[:6]}"
                self.battle_start_time = time.time()
                self.memory_manager.new_battle(self.current_battle_id)
                logger.info(f"战斗开始: {self.current_battle_id}")
            
            if target_phase == GamePhase.结算 and self.current_battle_id:
                self._on_battle_end(state)
    
    def _on_battle_end(self, state: BattleState):
        """战斗结束处理"""
        duration = time.time() - self.battle_start_time
        
        my_alive = sum(1 for p in state.my_pets if p.is_alive) if state.my_pets else 0
        result = "win" if my_alive > 0 else "lose"
        
        logger.info(f"战斗结束: {result}, 耗时 {duration:.1f}s")
        
        # 保存记忆
        if self.memory_manager.current_memory:
            self.memory_manager.save()
        
        # 保存战斗记录和分析
        if self.current_battle_id:
            record = self.replay_analyzer.create_record_from_history(
                battle_id=self.current_battle_id,
                result=result,
                turn_history=self.strategy_agent.conversation_history
            )
            record.duration_seconds = duration
            self.replay_analyzer.save_battle_record(record)
            
            if result == "lose":
                analysis = self.replay_analyzer.analyze_defeat(record)
                logger.info(f"失败分析:\n{analysis}")
                new_rules = self.replay_analyzer.extract_rules_from_defeat(record)
                logger.info(f"提取了 {len(new_rules)} 条学习规则")
        
        self.current_battle_id = None
        self.memory_manager.clear()
    
    # ──────────────────────────────────────────────────────────────
    # 单步执行（调试/测试）
    # ──────────────────────────────────────────────────────────────
    
    def step(self) -> Dict[str, Any]:
        """单步执行一个完整的决策周期"""
        screenshot_path = f"/tmp/step_{int(time.time())}.png"
        self.executor.screenshot(screenshot_path)
        
        state = self.vision_parser.parse_screenshot(screenshot_path)
        self._update_memory(state)
        
        self.battle_engine.update_state(state)
        rec = self.battle_engine.analyze()
        
        memory_context = ""
        if self.memory_manager.current_memory:
            memory_context = self.memory_manager.current_memory.get_full_context()
        
        action = self.strategy_agent.decide(state, rec, memory_context)
        
        # Rule验证
        validation = self.rule_agent.validate(action, state)
        
        return {
            "state": state,
            "recommendation": rec,
            "action": action,
            "validation": validation,
            "memory_context": memory_context,
            "phase": self.state_machine.current_phase.value,
        }