"""
luo_king_agent/learning/replay_analyzer.py
============================================
Operator的要求：
  "AI以后应该：学习自己的失败。"
  "保存：第15回合，为什么输了？因为换宠慢了。"
  "以后：同样情况，AI自动不要再这样换。"

这个模块负责：
- 保存每一局战斗的完整记录
- 分析失败原因
- 形成经验规则
- 在下一次战斗中应用
"""

from __future__ import annotations
from typing import List, Dict, Optional, Any
from dataclasses import dataclass, field, asdict
import json
import logging
import os
from datetime import datetime

from ..core.models import (
    BattleState, BattleAction, BattleActionType,
    GamePhase, PetState
)

logger = logging.getLogger(__name__)


@dataclass
class TurnRecord:
    """单回合记录"""
    turn_number: int
    state_before: str           # 行动前状态文本
    action: str                 # 采取的行动
    action_reasoning: str       # 决策理由
    state_after: str            # 行动后状态文本
    consequence: str = ""       # 行动后果（如"造成伤害120"、"换宠成功"）
    score: float = 0.0          # 该回合评分


@dataclass
class BattleRecord:
    """整局战斗记录"""
    battle_id: str
    timestamp: str
    result: str                 # "win" / "lose" / "draw"
    duration_seconds: float
    total_turns: int
    my_pets_used: List[str] = field(default_factory=list)
    enemy_pets: List[str] = field(default_factory=list)
    turns: List[TurnRecord] = field(default_factory=list)
    critical_turns: List[int] = field(default_factory=list)  # 关键转折点
    analysis: str = ""          # 整体分析（AI总结）


@dataclass
class LearnedRule:
    """从失败中学习的规则"""
    rule_id: str
    condition: str              # 触发条件，如"对方HP<30%且我方有克制技能"
    recommended_action: str     # 建议动作
    avoid_action: str           # 应避免的动作
    source_battle_id: str       # 来源战斗
    confidence: float = 0.5     # 置信度
    times_applied: int = 0      # 应用次数
    times_success: int = 0      # 成功次数


class ReplayAnalyzer:
    """
    回放分析器 - 从失败中学习。
    
    工作流程：
    1. 战斗结束后，保存BattleRecord到磁盘
    2. 对失败的战斗，调用LLM分析原因
    3. 提取关键回合的错误决策
    4. 形成LearnedRule
    5. 下次战斗时，策略Agent参考已有规则
    """
    
    def __init__(self, data_dir: str = "data/battles"):
        self.data_dir = data_dir
        self.rules: List[LearnedRule] = []
        self._ensure_data_dir()
        self._load_rules()
    
    def _ensure_data_dir(self):
        """确保数据目录存在"""
        os.makedirs(self.data_dir, exist_ok=True)
        os.makedirs(f"{self.data_dir}/records", exist_ok=True)
        os.makedirs(f"{self.data_dir}/rules", exist_ok=True)
    
    def _load_rules(self):
        """加载已有的学习规则"""
        rules_file = f"{self.data_dir}/rules/learned_rules.json"
        if os.path.exists(rules_file):
            try:
                with open(rules_file, "r") as f:
                    data = json.load(f)
                    self.rules = [LearnedRule(**r) for r in data]
                logger.info(f"加载了 {len(self.rules)} 条学习规则")
            except Exception as e:
                logger.error(f"加载规则失败: {e}")
    
    # ──────────────────────────────────────────────────────────────
    # 记录保存
    # ──────────────────────────────────────────────────────────────
    
    def save_battle_record(self, record: BattleRecord):
        """保存战斗记录"""
        filename = f"{self.data_dir}/records/{record.battle_id}.json"
        try:
            with open(filename, "w") as f:
                json.dump(asdict(record), f, ensure_ascii=False, indent=2)
            logger.info(f"战斗记录已保存: {filename}")
        except Exception as e:
            logger.error(f"保存战斗记录失败: {e}")
    
    def create_record_from_history(self, battle_id: str, result: str,
                                    turn_history: List[Dict]) -> BattleRecord:
        """从决策历史创建战斗记录"""
        record = BattleRecord(
            battle_id=battle_id,
            timestamp=datetime.now().isoformat(),
            result=result,
            duration_seconds=0.0,
            total_turns=len(turn_history),
        )
        
        for t in turn_history:
            turn_rec = TurnRecord(
                turn_number=t.get("turn", 0),
                state_before=t.get("state", ""),
                action=t.get("decision", ""),
                action_reasoning=t.get("reasoning", ""),
                state_after="",
            )
            record.turns.append(turn_rec)
        
        return record
    
    # ──────────────────────────────────────────────────────────────
    # 失败分析
    # ──────────────────────────────────────────────────────────────
    
    def analyze_defeat(self, record: BattleRecord) -> str:
        """
        分析失败原因。
        找出关键转折点，提取可学习的内容。
        """
        analysis_parts = []
        
        # 1. 找HP最低的回合
        # 2. 找换宠时机
        # 3. 找技能使用错误
        
        # 简化分析：找前5回合和后5回合的对比
        if len(record.turns) > 10:
            early_turns = record.turns[:5]
            late_turns = record.turns[-5:]
            
            # 分析初期优势是否被浪费
            analysis_parts.append("初期行动分析：")
            for t in early_turns:
                analysis_parts.append(f"  第{t.turn_number}回合: {t.action} ({t.action_reasoning})")
            
            analysis_parts.append("\n后期行动分析：")
            for t in late_turns:
                analysis_parts.append(f"  第{t.turn_number}回合: {t.action} ({t.action_reasoning})")
        
        record.analysis = "\n".join(analysis_parts)
        return record.analysis
    
    def extract_rules_from_defeat(self, record: BattleRecord) -> List[LearnedRule]:
        """
        从失败中提取规则。
        这是真正的"学习"过程。
        """
        new_rules = []
        
        for i, turn in enumerate(record.turns):
            # 检查是否有换宠决策
            if "换宠" in turn.action:
                # 检查换宠后的结果
                # 如果换宠后局势恶化，记录为"避免该换宠"
                rule = LearnedRule(
                    rule_id=f"rule_{len(self.rules) + len(new_rules) + 1}",
                    condition=f"第{turn.turn_number}回合类似局势",
                    recommended_action="考虑其他策略",
                    avoid_action=turn.action,
                    source_battle_id=record.battle_id,
                    confidence=0.3,
                )
                new_rules.append(rule)
        
        # 保存新规则
        self.rules.extend(new_rules)
        self._save_rules()
        
        return new_rules
    
    def _save_rules(self):
        """保存规则到磁盘"""
        rules_file = f"{self.data_dir}/rules/learned_rules.json"
        try:
            with open(rules_file, "w") as f:
                json.dump([asdict(r) for r in self.rules], f, ensure_ascii=False, indent=2)
        except Exception as e:
            logger.error(f"保存规则失败: {e}")
    
    # ──────────────────────────────────────────────────────────────
    # 规则应用
    # ──────────────────────────────────────────────────────────────
    
    def get_relevant_rules(self, state: BattleState) -> List[LearnedRule]:
        """获取与当前状态相关的学习规则"""
        relevant = []
        state_text = state.to_prompt_context()
        
        for rule in self.rules:
            # 简单匹配：检查规则条件是否出现在当前状态中
            if any(word in state_text for word in rule.condition.split()):
                relevant.append(rule)
        
        return relevant
    
    def update_rule_confidence(self, rule_id: str, success: bool):
        """更新规则置信度"""
        for rule in self.rules:
            if rule.rule_id == rule_id:
                rule.times_applied += 1
                if success:
                    rule.times_success += 1
                rule.confidence = rule.times_success / rule.times_applied
                break
        self._save_rules()