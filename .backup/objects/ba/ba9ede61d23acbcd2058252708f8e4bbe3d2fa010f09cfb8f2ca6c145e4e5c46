    草 = "grass"
    电 = "electric"
    冰 = "ice"
    格斗 = "fighting"
    毒 = "poison"
    地面 = "ground"
    飞行 = "flying"
    超能力 = "psychic"
    虫 = "bug"
    岩石 = "rock"
    幽灵 = "ghost"
    龙 = "dragon"
    恶 = "dark"
    钢 = "steel"
    妖精 = "fairy"
    萌 = "cute"  # 洛克王国特有


class WeatherType(Enum):
    晴天 = "sunny"
    雨天 = "rainy"
    暴风雪 = "snowstorm"
    沙暴 = "sandstorm"
    迷雾 = "mist"
