    无 = "none"
    中毒 = "poisoned"
    剧毒 = "badly_poisoned"
    麻痹 = "paralyzed"
    烧伤 = "burned"
    冰冻 = "frozen"
    睡眠 = "sleeping"
    迷惑 = "confused"
    害怕 = "scared"


class BuffType(Enum):
    """能力等级变化"""
    攻击 = "attack"
    防御 = "defense"
    魔攻 = "sp_attack"
    魔抗 = "sp_defense"
    速度 = "speed"
    命中 = "accuracy"
