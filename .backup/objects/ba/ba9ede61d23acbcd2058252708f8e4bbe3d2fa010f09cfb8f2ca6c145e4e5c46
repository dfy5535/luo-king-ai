# ──────────────────────────────────────────────────────────────────────
# 2. 核心数据类 - 这就是AI真正需要的"状态"
# ──────────────────────────────────────────────────────────────────────

@dataclass
class PetState:
    """一只宠物的完整状态 - 不超过50个字段"""
    # 身份
    name: str                           # 名称，如"烈火战神"
    pet_id: Optional[int] = None        # 图鉴ID
    types: List[PetType] = field(default_factory=list)  # 属性列表，如 [火]

    # 战斗状态
    hp_current: int = 0
    hp_max: int = 0
    hp_percent: float = 0.0             # 0.0 ~ 1.0

    # 技能
    skills: List[SkillState] = field(default_factory=list)  # 最多4个
    pp_total: int = 0                   # 总PP剩余
    pp_max: int = 0                     # 总PP上限

    # 能力等级变化
    buffs: Dict[BuffType, int] = field(default_factory=dict)  # -6 ~ +6

    # 异常状态
    status: StatusCondition = StatusCondition.无
    status_turns: int = 0               # 异常持续回合数

    # 其他
    level: int = 100
    is_alive: bool = True
    is_active: bool = False             # 是否当前出战

    def __post_init__(self):
        self.hp_percent = (self.hp_current / self.hp_max) if self.hp_max > 0 else 0.0

    def to_compact_dict(self) -> Dict[str, Any]:
        """压缩表示 - 只给AI看到真正需要的东西"""
        return {
            "name": self.name,
            "types": [t.value for t in self.types],
            "hp": f"{self.hp_current}/{self.hp_max} ({self.hp_percent:.0%})",
            "skills": [s.to_compact_dict() for s in self.skills],
            "buffs": {k.value: v for k, v in self.buffs.items() if v != 0},
            "status": self.status.value if self.status != StatusCondition.无 else None,
            "alive": self.is_alive,
        }


@dataclass
class SkillState:
    """技能状态"""
    name: str
    skill_type: PetType = PetType.普通
    power: int = 0                      # 威力
    pp_current: int = 0
    pp_max: int = 0
    accuracy: float = 1.0               # 命中率
    is_sealed: bool = False             # 是否被封印
    category: str = "physical"          # physical / special / status
    priority: int = 0                   # 先手度

    def to_compact_dict(self) -> Dict[str, Any]:
        """压缩表示"""
        return {
            "name": self.name,
            "pp": f"{self.pp_current}/{self.pp_max}",
            "sealed": self.is_sealed,
            "type": self.skill_type.value,
        }


@dataclass
class BattleState:
    """
    完整战斗状态。
    这是整个视觉系统的输出，也是战斗引擎的输入。
    整个智能体围绕这个数据结构运转。
    """
    # ── 基础信息 ──
    phase: GamePhase = GamePhase.未知
    is_my_turn: bool = False
    turn_number: int = 0

    # ── 我方 ──
    my_pets: List[PetState] = field(default_factory=list)       # 所有宠物
    my_active: Optional[PetState] = None                         # 当前出战

    # ── 敌方 ──
    enemy_pet: Optional[PetState] = None                         # 敌方当前宠物
    enemy_pets_known: List[PetState] = field(default_factory=list)  # 已知敌方阵容

    # ── 战场环境 ──
    weather: WeatherType = WeatherType.无
    battlefield_effects: Dict[str, Any] = field(default_factory=dict)  # 如"护盾","反射","陷阱"

    # ── 回合信息 ──
    my_last_action: Optional[BattleAction] = None
    enemy_last_action: Optional[BattleAction] = None
    available_actions: List[BattleActionType] = field(default_factory=list)

    # ── 元数据 ──
    screenshot_timestamp: float = 0.0
    parse_confidence: float = 0.0       # 视觉解析置信度
    raw_text_detected: List[str] = field(default_factory=list)  # OCR原始文本

    def to_prompt_context(self) -> str:
        """
        压缩成AI能理解的短文本。
        这就是AI真正"看到"的世界。
        不是3MB图片，是几百字的精确状态。
        """
        lines = []
        lines.append(f"=== 第 {self.turn_number} 回合 ===")
        lines.append(f"{'我方' if self.is_my_turn else '敌方'}回合")
        lines.append(f"天气: {self.weather.value}")

        # 我方
        if self.my_active:
            m = self.my_active
            lines.append(f"【我方出战】{m.name} ({'/'.join(t.value for t in m.types)})")
            lines.append(f"  HP: {m.hp_current}/{m.hp_max} ({m.hp_percent:.0%})")
            for s in m.skills:
                status = " [封印]" if s.is_sealed else ""
                lines.append(f"  技能: {s.name} PP {s.pp_current}/{s.pp_max}{status}")
            if m.buffs:
                buff_str = ", ".join(f"{k.value}: {v:+d}" for k, v in m.buffs.items() if v != 0)
                lines.append(f"  能力变化: {buff_str}")
            if m.status != StatusCondition.无:
                lines.append(f"  异常: {m.status.value}")

        # 敌方
        if self.enemy_pet:
            e = self.enemy_pet
            lines.append(f"【敌方出战】{e.name} ({'/'.join(t.value for t in e.types)})")
            lines.append(f"  HP: {e.hp_current}/{e.hp_max} ({e.hp_percent:.0%})")
            if e.buffs:
                buff_str = ", ".join(f"{k.value}: {v:+d}" for k, v in e.buffs.items() if v != 0)
                lines.append(f"  能力变化: {buff_str}")
            if e.status != StatusCondition.无:
                lines.append(f"  异常: {e.status.value}")

        # 所有我方宠物
        if len(self.my_pets) > 1:
            lines.append("【我方阵容】")
            for p in self.my_pets:
                if p != self.my_active:
                    lines.append(f"  {p.name} HP: {p.hp_current}/{p.hp_max} {'[阵亡]' if not p.is_alive else ''}")

        return "\n".join(lines)


@dataclass
class BattleAction:
    """一个战斗动作"""
    action_type: BattleActionType
    target: Optional[str] = None        # 技能名/宠物名
    confidence: float = 0.0
    reasoning: str = ""                 # AI的思考过程


@dataclass
class ScreenCoordinate:
    """屏幕坐标"""
    x: int
    y: int
    width: int = 0
    height: int = 0
    label: str = ""

    def center(self) -> tuple:
        return (self.x + self.width // 2, self.y + self.height // 2)


