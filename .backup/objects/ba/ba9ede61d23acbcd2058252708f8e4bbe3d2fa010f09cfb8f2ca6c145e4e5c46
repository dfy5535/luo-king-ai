class GamePhase(Enum):
    """游戏阶段 - 状态机核心枚举"""
    登录 = "login"
    大厅 = "lobby"
    匹配中 = "matching"
    选宠 = "pet_select"
    战斗 = "battle"
    换宠 = "pet_swap"
    结算 = "settlement"
