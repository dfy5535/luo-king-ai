package com.luoking.agent

import android.util.Log
import com.luoking.agent.models.SessionState
import kotlinx.coroutines.*
import okhttp3.*
import org.json.JSONObject
import java.util.concurrent.TimeUnit

/**
 * WebSocket 客户端 - 状态机驱动
 *
 * 状态流转：
 *   DISCONNECTED ──connect()──→ CONNECTING
 *       ↓ onOpen                    ↓
 *   CONNECTED (WebSocket 通了)      ↓
 *       ↓ 首次心跳（无 session_id）  ↓
 *       ↓ 收到 heartbeat_ack        ↓
 *   SESSION_ESTABLISHED ──→ 回调 onSessionEstablished()
 *       ↓ 持续心跳（带 session_id）
 *       ↓ 断线
 *   DISCONNECTED ──→ 清空 session_id → 重连 → 重新走流程
 *
 * 两条硬规则：
 * 1. heartbeat_ack 之前，禁止 upload / action_result
 * 2. 断线重连后，SessionState.sessionId 立刻清空，必须重新握手
 */
class WebSocketClient(
    private val serverUrl: String,
    private val onAction: (JSONObject) -> Unit,
    /** WebSocket 连接建立（非会话建立，仅用于 UI 更新） */
    private val onConnected: () -> Unit = {},
    /** session_id 到手，可以开始截图 */
    private val onSessionEstablished: () -> Unit = {},
    private val onDisconnected: () -> Unit = {}
) {
    companion object {
        private const val TAG = "WSClient"
        private const val HEARTBEAT_INTERVAL = 5000L
        private const val RECONNECT_DELAY = 3000L
        private const val MAX_RECONNECT_DELAY = 30000L
    }

    private enum class State { DISCONNECTED, CONNECTING, CONNECTED, SESSION_ESTABLISHED }
    private var state = State.DISCONNECTED

    private var ws: WebSocket? = null
    private val scope = CoroutineScope(Dispatchers.IO + SupervisorJob())
    private var heartbeatJob: Job? = null
    private var reconnectAttempts = 0

    private val client = OkHttpClient.Builder()
        .pingInterval(10, TimeUnit.SECONDS)
        .readTimeout(30, TimeUnit.SECONDS)
        .writeTimeout(30, TimeUnit.SECONDS)
        .build()

    // ── 公开状态查询 ──

    /** 是否已建立会话（session_id 到手） */
    fun isSessionEstablished(): Boolean = state == State.SESSION_ESTABLISHED

    /** 当前 session_id（可能为空） */
    fun getSessionId(): String? = if (state >= State.SESSION_ESTABLISHED) SessionState.sessionId else null

    // ── 连接管理 ──

    fun connect() {
        if (state >= State.CONNECTING) {
            Log.d(TAG, "已在连接中或已连接，忽略重复 connect")
            return
        }
        state = State.CONNECTING
        SessionState.sessionId = ""  // 重置 session_id
        reconnectAttempts = 0

        val request = Request.Builder().url(serverUrl).build()
        ws = client.newWebSocket(request, object : WebSocketListener() {
            override fun onOpen(ws: WebSocket, response: Response) {
                state = State.CONNECTED
                SessionState.isConnected = true
                Log.d(TAG, "WebSocket 已连接: $serverUrl")
                onConnected()
                // 首次心跳，不带 session_id
                sendHeartbeat()
            }

            override fun onMessage(ws: WebSocket, text: String) {
                try {
                    val json = JSONObject(text)
                    when (json.optString("type", "")) {
                        "heartbeat_ack" -> {
                            val sid = json.optString("session_id", "")
                            if (sid.isNotEmpty()) {
                                val prevState = state
                                state = State.SESSION_ESTABLISHED
                                SessionState.sessionId = sid
                                Log.d(TAG, "session_id 已分配: $sid (状态: ${prevState.name} → SESSION_ESTABLISHED)")

                                // 首次建立会话时，通知外部可以开始截图
                                if (prevState < State.SESSION_ESTABLISHED) {
                                    onSessionEstablished()
                                    // 开始周期性心跳
                                    startHeartbeat()
                                }
                            }
                        }
                        "action" -> {
                            if (state < State.SESSION_ESTABLISHED) {
                                Log.w(TAG, "会话未建立，忽略动作指令")
                                return@let
                            }
                            Log.d(TAG, "收到动作: ${json.optString("action_type")}")
                            SessionState.totalActions++
                            onAction(json)
                        }
                        "error" -> {
                            Log.e(TAG, "服务器错误: [${json.optString("code")}] ${json.optString("message")}")
                        }
                    }
                } catch (e: Exception) {
                    Log.e(TAG, "消息解析失败", e)
                }
            }

            override fun onClosed(ws: WebSocket, code: Int, reason: String) {
                Log.d(TAG, "连接关闭: $reason (code=$code)")
                cleanup()
                onDisconnected()
                scheduleReconnect()
            }

            override fun onFailure(ws: WebSocket, t: Throwable, response: Response?) {
                Log.e(TAG, "连接失败: ${t.message}")
                cleanup()
                onDisconnected()
                scheduleReconnect()
            }
        })
    }

    fun disconnect() {
        cleanup()
        ws?.close(1000, "用户断开")
        Log.d(TAG, "用户主动断开")
    }

    /**
     * 清理所有状态。
     * 断线/失败时调用，清空 session_id，必须重新握手。
     */
    private fun cleanup() {
        heartbeatJob?.cancel()
        heartbeatJob = null
        state = State.DISCONNECTED
        SessionState.isConnected = false
        SessionState.sessionId = ""  // 重要：清空 session_id
    }

    // ── 发送 ──

    /**
     * 发送心跳。
     * 首次心跳不带 session_id，后续心跳带上。
     */
    fun sendHeartbeat() {
        if (state < State.CONNECTED) return
        val json = JSONObject().apply {
            put("type", "heartbeat")
            put("device_id", SessionState.deviceId)
            put("phase", SessionState.phase)
            put("battery", 0)
            put("ts", System.currentTimeMillis() / 1000)
            // SESSION_ESTABLISHED 后带上 session_id
            if (state >= State.SESSION_ESTABLISHED) {
                put("session_id", SessionState.sessionId)
            }
        }
        send(json.toString())
    }

    /**
     * 上传截图。
     * 规则：heartbeat_ack 之前禁止调用。
     * 如果 session_id 为空，丢弃并记录警告。
     */
    fun sendScreenshot(base64: String) {
        if (state < State.SESSION_ESTABLISHED) {
            Log.w(TAG, "会话未建立（state=$state），丢弃截图上传")
            return
        }
        val sid = SessionState.sessionId
        if (sid.isEmpty()) {
            Log.w(TAG, "session_id 为空，丢弃截图上传")
            return
        }
        send(JSONObject().apply {
            put("type", "upload")
            put("device_id", SessionState.deviceId)
            put("session_id", sid)
            put("image", base64)
            put("ts", System.currentTimeMillis() / 1000)
        }.toString())
    }

    fun sendActionResult(success: Boolean) {
        if (state < State.SESSION_ESTABLISHED) return
        val sid = SessionState.sessionId
        if (sid.isEmpty()) return
        send(JSONObject().apply {
            put("type", "action_result")
            put("device_id", SessionState.deviceId)
            put("session_id", sid)
            put("success", success)
            put("ts", System.currentTimeMillis() / 1000)
        }.toString())
    }

    private fun send(message: String) {
        ws?.send(message)
    }

    // ── 内部 ──

    private fun startHeartbeat() {
        heartbeatJob?.cancel()
        heartbeatJob = scope.launch {
            while (isActive) {
                delay(HEARTBEAT_INTERVAL)
                if (state >= State.CONNECTED) sendHeartbeat()
            }
        }
    }

    private fun scheduleReconnect() {
        scope.launch {
            reconnectAttempts++
            val delay = minOf(
                RECONNECT_DELAY * (1 shl (reconnectAttempts - 1)),
                MAX_RECONNECT_DELAY
            )
            Log.d(TAG, "${delay}ms 后重连 (第${reconnectAttempts}次)")
            delay(delay)
            connect()
        }
    }
}