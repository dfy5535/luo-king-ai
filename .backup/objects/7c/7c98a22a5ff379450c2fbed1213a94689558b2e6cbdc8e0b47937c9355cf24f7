"""
luo_king_agent/vision/llm_parser.py
=====================================
Operator 的三条铁律：

  1) 输入只收截图
     → 只传截图，不传多余上下文。这一层只做"看见什么"，不做推理。

  2) 输出只准 JSON
     → 必须固定字段，不能输出散文，不能自由发挥。

  3) 失败就重试，不允许猜
     → 识别不清时返回 null、unknown 或 confidence 降低，不准编造。

输出协议（永远一致）：

  {
    "phase": "battle",
    "turn": 5,
    "weather": "sunny",
    "self": {
      "pet_name": "烈火战神",
      "hp": 156,
      "hp_max": 200,
      "status": [],
      "buffs": {"speed": 1},
      "skills": [
        {"name": "烈焰冲锋", "pp": 8, "pp_max": 10},
        ...
      ]
    },
    "enemy": {
      "pet_name": "冰龙王",
      "hp": 82,
      "hp_max": 220,
      "status": ["freeze"]
    },
    "available_actions": ["skill_1", "skill_2", "skill_3", "skill_4", "switch"],
    "confidence": 0.94
  }
"""

from __future__ import annotations
from typing import Optional, List, Dict, Any, Tuple
from dataclasses import dataclass, field, asdict
import logging
import json
import base64
import os
import time

from ..core.models import (
    BattleState, PetState, SkillState, PetType, WeatherType,
    StatusCondition, BuffType, GamePhase, BattleActionType,
)

logger = logging.getLogger(__name__)


# ──────────────────────────────────────────────────────────────────────
# 1. 视觉输出协议（Transport Layer）
#    VisionResult 是 LLM 输出与 BattleState 之间的"契约"。
#    字段永远固定，不存在任何自由发挥的空间。
# ──────────────────────────────────────────────────────────────────────

@dataclass
class VisionSkill:
    """技能条目——协议层"""
    name: str
    pp: int
    pp_max: int


@dataclass
class VisionPet:
    """宠物条目——协议层"""
    pet_name: str
    hp: int
    hp_max: int
    status: List[str] = field(default_factory=list)
    buffs: Dict[str, int] = field(default_factory=dict)
    skills: List[VisionSkill] = field(default_factory=list)


@dataclass
class VisionResult:
    """
    视觉解析结果——协议层。
    
    这是 LLM 输出的直接映射。
    字段固定，类型固定，不存在自由文本。
    
    注意：
    - 所有不可见字段为 null（Python 中为 None）
    - 所有状态列表为空列表 [] 表示无异常
    - confidence 为 0.0 表示完全不可信
    """
    phase: Optional[str] = None          # "battle" | "lobby" | "matching" | ...
    turn: Optional[int] = None           # 回合数
    weather: Optional[str] = None        # "sunny" | "rainy" | ...
    self: Optional[VisionPet] = None     # 我方出战宠物
    enemy: Optional[VisionPet] = None    # 敌方当前宠物
    available_actions: List[str] = field(default_factory=list)
    confidence: float = 0.0              # 0.0 ~ 1.0


# ──────────────────────────────────────────────────────────────────────
# 2. 字段缺失检测器
#    严格检查输出是否包含所有必需字段。
#    缺字段就重试，别硬跑。
# ──────────────────────────────────────────────────────────────────────

REQUIRED_FIELDS_BATTLE = [
    "self.pet_name",
    "self.hp",
    "self.hp_max",
    "self.skills",
    "enemy.pet_name",
    "enemy.hp",
    "enemy.hp_max",
]

# 重试配置
MAX_RETRIES = 3
CONFIDENCE_HIGH = 0.90      # ≥0.90：直接进入引擎
CONFIDENCE_ACCEPTABLE = 0.70  # 0.70~0.89：可接受
CONFIDENCE_LOW = 0.70       # <0.70：重新截图


class VisionValidator:
    """
    视觉输出校验器。
    
    职责：
    - 检查必需字段是否完整
    - 检查字段类型是否正确
    - 检查值是否在合法范围内
    - 返回缺失字段列表
    """
    
    @staticmethod
    def check_required(result: VisionResult, phase: str) -> List[str]:
        """
        检查必需字段是否完整。
        
        Returns:
            缺失字段列表（空列表表示全部完整）
        """
        missing = []
        
        if phase == "battle":
            for field_path in REQUIRED_FIELDS_BATTLE:
                if not VisionValidator._get_field(result, field_path):
                    missing.append(field_path)
        elif phase in ("lobby", "matching", "pet_select", "settlement", "login"):
            # 非战斗阶段只需要 phase
            pass
        
        return missing
    
    @staticmethod
    def check_types(result: VisionResult) -> List[str]:
        """检查字段类型是否正确"""
        errors = []
        
        if result.self:
            if not isinstance(result.self.hp, int):
                errors.append("self.hp 不是整数")
            if not isinstance(result.self.hp_max, int):
                errors.append("self.hp_max 不是整数")
            if result.self.hp_max and result.self.hp_max < 0:
                errors.append("self.hp_max 为负数")
            for skill in result.self.skills:
                if not isinstance(skill.pp, int):
                    errors.append(f"skill {skill.name}.pp 不是整数")
        
        if result.enemy:
            if not isinstance(result.enemy.hp, int):
                errors.append("enemy.hp 不是整数")
            if not isinstance(result.enemy.hp_max, int):
                errors.append("enemy.hp_max 不是整数")
        
        if not isinstance(result.confidence, (int, float)):
            errors.append("confidence 不是数字")
        elif result.confidence < 0 or result.confidence > 1:
            errors.append(f"confidence {result.confidence} 超出 [0,1] 范围")
        
        return errors
    
    @staticmethod
    def check_values(result: VisionResult) -> List[str]:
        """检查值是否在合法范围内"""
        warnings = []
        
        if result.self:
            if result.self.hp > result.self.hp_max:
                warnings.append(f"self.hp ({result.self.hp}) > self.hp_max ({result.self.hp_max})")
            if result.self.hp < 0:
                warnings.append(f"self.hp ({result.self.hp}) 为负数")
        
        if result.enemy:
            if result.enemy.hp > result.enemy.hp_max:
                warnings.append(f"enemy.hp ({result.enemy.hp}) > enemy.hp_max ({result.enemy.hp_max})")
            if result.enemy.hp < 0:
                warnings.append(f"enemy.hp ({result.enemy.hp}) 为负数")
        
        return warnings
    
    @staticmethod
    def _get_field(obj: Any, path: str) -> Any:
        """通过点路径获取字段值"""
        parts = path.split(".")
        current = obj
        for part in parts:
            if isinstance(current, dict):
                current = current.get(part)
            else:
                current = getattr(current, part, None) if hasattr(current, part) else None
            if current is None:
                return None
        return current


# ──────────────────────────────────────────────────────────────────────
# 3. 核心解析器
#    只做三件事：截图 → Base64 → 调用 SenseNova → 解析 JSON → 返回 VisionResult
#    不做任何决策、推理、分析。
# ──────────────────────────────────────────────────────────────────────

# 系统提示词——只做结构化提取，不做解释
SYSTEM_PROMPT = """你是一个游戏战斗状态提取器。
你只负责从截图中提取可见信息，并输出严格 JSON。
不要分析策略，不要建议操作，不要解释原因。
如果某个字段无法确认，填 null。
如果某个值看不清，优先保持保守，不要猜测。
输出必须符合给定结构，不能包含多余文本。"""

# 用户提示词——仅一句话，不加任何上下文
USER_PROMPT = "请从这张游戏截图中提取战斗状态，严格输出 JSON。"


class LLMVisionParser:
    """
    基于多模态 LLM 的视觉解析器。
    
    三条铁律：
    1) 输入只收截图——不传多余上下文
    2) 输出只准 JSON——固定字段，不自由发挥
    3) 失败就重试——不允许猜
    
    使用方式：
        parser = LLMVisionParser(llm_client=openai_client)
        result = parser.parse_screenshot("screenshot.png")
        # result 是 VisionResult，包含所有协议字段
        
        battle_state = parser.to_battle_state(result)
        # 转换为 BattleState 供下游引擎使用
    """
    
    def __init__(self, llm_client=None, model: str = "sensenova-6.7-flash-lite"):
        self.llm_client = llm_client
        self.model = model
        self.validator = VisionValidator()
        
        # 统计信息
        self.total_calls = 0
        self.retry_count = 0
        self.failure_count = 0
    
    # ──────────────────────────────────────────────────────────────
    # 公开接口
    # ──────────────────────────────────────────────────────────────
    
    def parse_screenshot(self, image_path: str, max_retries: int = MAX_RETRIES) -> VisionResult:
        """
        解析截图 → VisionResult。
        
        规则：
        - 只传截图，不传多余上下文
        - 输出只准 JSON
        - 失败就重试，不允许猜
        
        Args:
            image_path: 截图路径
            max_retries: 最大重试次数
            
        Returns:
            VisionResult: 协议层结果
        """
        self.total_calls += 1
        
        # 准备图片
        image_data, media_type = self._prepare_image(image_path)
        if image_data is None:
            return VisionResult(confidence=0.0)
        
        # 重试循环
        last_error = ""
        for attempt in range(max_retries):
            try:
                llm_json = self._call_llm(image_data, media_type)
                result = self._parse_to_vision_result(llm_json)
                
                # 校验
                missing = self.validator.check_required(result, result.phase or "unknown")
                type_errors = self.validator.check_types(result)
                value_warnings = self.validator.check_values(result)
                
                # 记录日志
                if missing:
                    logger.warning(f"缺失字段 (第{attempt+1}次): {missing}")
                if type_errors:
                    logger.warning(f"类型错误 (第{attempt+1}次): {type_errors}")
                if value_warnings:
                    logger.debug(f"值警告 (第{attempt+1}次): {value_warnings}")
                
                # 判断是否通过
                if not missing and not type_errors:
                    if result.confidence >= CONFIDENCE_ACCEPTABLE:
                        logger.info(
                            f"视觉解析成功: {result.self.pet_name if result.self else '?'} "
                            f"vs {result.enemy.pet_name if result.enemy else '?'} "
                            f"置信度={result.confidence:.2f}"
                        )
                        return result
                    else:
                        logger.warning(
                            f"置信度不足 ({result.confidence:.2f} < {CONFIDENCE_ACCEPTABLE})，"
                            f"第{attempt+1}/{max_retries}次重试"
                        )
                else:
                    logger.warning(
                        f"校验失败，第{attempt+1}/{max_retries}次重试"
                    )
                
                last_error = f"missing={missing} types={type_errors}"
                
            except json.JSONDecodeError as e:
                last_error = f"JSON解析失败: {e}"
                logger.warning(f"JSON解析失败 (第{attempt+1}次): {e}")
            except Exception as e:
                last_error = f"API调用失败: {e}"
                logger.warning(f"API调用失败 (第{attempt+1}次): {e}")
            
            self.retry_count += 1
            if attempt < max_retries - 1:
                time.sleep(1.0)  # 重试前等待
        
        # 所有重试失败
        self.failure_count += 1
        logger.error(f"视觉解析最终失败，已重试{max_retries}次: {last_error}")
        return VisionResult(
            confidence=0.0,
            phase="unknown"
        )
    
    def to_battle_state(self, result: VisionResult) -> BattleState:
        """
        将 VisionResult 转换为 BattleState。
        
        这是协议层 → 核心模型的转换。
        纯粹的数据映射，不包含任何逻辑判断。
        """
        state = BattleState()
        state.screenshot_timestamp = time.time()
        state.parse_confidence = result.confidence
        
        # 阶段
        phase_map = {
            "battle": GamePhase.战斗,
            "lobby": GamePhase.大厅,
            "matching": GamePhase.匹配中,
            "pet_select": GamePhase.选宠,
            "settlement": GamePhase.结算,
            "login": GamePhase.登录,
        }
        state.phase = phase_map.get(result.phase or "", GamePhase.未知)
        
        # 回合
        state.turn_number = result.turn or 0
        state.is_my_turn = (result.phase == "battle")
        
        # 天气
        weather_map = {
            "sunny": WeatherType.晴天,
            "rainy": WeatherType.雨天,
            "snowstorm": WeatherType.暴风雪,
            "sandstorm": WeatherType.沙暴,
            "mist": WeatherType.迷雾,
        }
        state.weather = weather_map.get(result.weather or "", WeatherType.无)
        
        # 我方
        if result.self:
            my_pet = self._pet_result_to_state(result.self)
            my_pet.is_active = True
            state.my_active = my_pet
            state.my_pets.append(my_pet)
        
        # 敌方
        if result.enemy:
            enemy = self._pet_result_to_state(result.enemy)
            enemy.is_active = True
            state.enemy_pet = enemy
        
        # 可用动作
        action_map = {
            "skill_1": BattleActionType.技能,
            "skill_2": BattleActionType.技能,
            "skill_3": BattleActionType.技能,
            "skill_4": BattleActionType.技能,
            "switch": BattleActionType.换宠,
            "item": BattleActionType.使用道具,
            "flee": BattleActionType.逃跑,
        }
        for action_str in result.available_actions:
            if action_str in action_map:
                state.available_actions.append(action_map[action_str])
        
        return state
    
    # ──────────────────────────────────────────────────────────────
    # 内部方法
    # ──────────────────────────────────────────────────────────────
    
    def _prepare_image(self, image_path: str) -> Tuple[Optional[str], Optional[str]]:
        """读取图片并转换为 Base64"""
        try:
            with open(image_path, "rb") as f:
                image_data = base64.b64encode(f.read()).decode("utf-8")
            
            ext = os.path.splitext(image_path)[1].lower()
            media_type = {
                ".png": "image/png",
                ".jpg": "image/jpeg",
                ".jpeg": "image/jpeg",
                ".webp": "image/webp",
            }.get(ext, "image/png")
            
            return image_data, media_type
        except Exception as e:
            logger.error(f"读取图片失败: {e}")
            return None, None
    
    def _call_llm(self, image_data: str, media_type: str) -> Dict[str, Any]:
        """调用 SenseNova 多模态模型"""
        response = self.llm_client.chat.completions.create(
            model=self.model,
            messages=[
                {"role": "system", "content": SYSTEM_PROMPT},
                {
                    "role": "user",
                    "content": [
                        {"type": "text", "text": USER_PROMPT},
                        {
                            "type": "image_url",
                            "image_url": {
                                "url": f"data:{media_type};base64,{image_data}"
                            }
                        }
                    ]
                }
            ],
            temperature=0.0,       # 零温度，完全确定性输出
            max_tokens=2000,
            response_format={"type": "json_object"},
        )
        
        content = response.choices[0].message.content
        return json.loads(content)
    
    def _parse_to_vision_result(self, data: Dict[str, Any]) -> VisionResult:
        """将 LLM 输出的 JSON 解析为 VisionResult"""
        result = VisionResult()
        
        # 基础字段
        result.phase = data.get("phase")
        result.turn = data.get("turn")
        result.weather = data.get("weather")
        result.confidence = float(data.get("confidence", 0.0))
        result.available_actions = data.get("available_actions", [])
        
        # 我方
        self_data = data.get("self")
        if self_data and isinstance(self_data, dict):
            result.self = self._parse_pet_json(self_data)
        
        # 敌方
        enemy_data = data.get("enemy")
        if enemy_data and isinstance(enemy_data, dict):
            result.enemy = self._parse_pet_json(enemy_data)
        
        return result
    
    def _parse_pet_json(self, data: Dict[str, Any]) -> VisionPet:
        """解析 JSON 中的宠物条目"""
        pet = VisionPet(
            pet_name=data.get("pet_name", ""),
            hp=data.get("hp", 0),
            hp_max=data.get("hp_max", 0),
            status=data.get("status", []),
            buffs=data.get("buffs", {}),
        )
        
        # 技能
        for skill_data in data.get("skills", []):
            if isinstance(skill_data, dict):
                pet.skills.append(VisionSkill(
                    name=skill_data.get("name", ""),
                    pp=skill_data.get("pp", 0),
                    pp_max=skill_data.get("pp_max", 0),
                ))
        
        return pet
    
    def _pet_result_to_state(self, pet: VisionPet) -> PetState:
        """将 VisionPet 转换为 PetState"""
        state_pet = PetState(
            name=pet.pet_name,
            hp_current=pet.hp,
            hp_max=pet.hp_max,
        )
        
        # 技能
        for skill in pet.skills:
            state_pet.skills.append(SkillState(
                name=skill.name,
                pp_current=skill.pp,
                pp_max=skill.pp_max,
            ))
        
        # 异常状态
        status_map = {
            "poisoned": StatusCondition.中毒,
            "badly_poisoned": StatusCondition.剧毒,
            "paralyzed": StatusCondition.麻痹,
            "burned": StatusCondition.烧伤,
            "frozen": StatusCondition.冰冻,
            "sleeping": StatusCondition.睡眠,
            "confused": StatusCondition.迷惑,
            "scared": StatusCondition.害怕,
        }
        if pet.status:
            first_status = pet.status[0].lower()
            state_pet.status = status_map.get(first_status, StatusCondition.无)
        
        # Buff
        buff_map = {
            "attack": BuffType.攻击, "defense": BuffType.防御,
            "sp_attack": BuffType.魔攻, "sp_defense": BuffType.魔抗,
            "speed": BuffType.速度, "accuracy": BuffType.命中,
            "evasion": BuffType.闪避,
        }
        for key, level in pet.buffs.items():
            enum_key = buff_map.get(key)
            if enum_key and level != 0:
                state_pet.buffs[enum_key] = level
        
        return state_pet


# ──────────────────────────────────────────────────────────────────────
# 4. 便捷函数
# ──────────────────────────────────────────────────────────────────────

def parse_screenshot_strict(
    image_path: str,
    llm_client,
    model: str = "sensenova-6.7-flash-lite",
    max_retries: int = MAX_RETRIES,
) -> BattleState:
    """
    便捷函数：截图 → BattleState（含重试和校验）。
    
    直接给 orchestrator 使用的单行接口。
    """
    parser = LLMVisionParser(llm_client=llm_client, model=model)
    result = parser.parse_screenshot(image_path, max_retries=max_retries)
    return parser.to_battle_state(result)