package com.luoking.agent

import android.util.Log
import kotlinx.coroutines.*
import org.json.JSONObject

/**
 * 动作执行器 - 执行服务器返回的点击指令
 *
 * 职责：
 * - 解析服务器返回的 ServerAction
 * - 调用 CaptureService 执行点击
 * - 上报执行结果
 */
class ActionExecutor(
    private val wsClient: WebSocketClient
) {
    companion object {
        private const val TAG = "ActionExecutor"

        // 技能按钮坐标（1920x1080，可根据分辨率缩放）
        private val SKILL_COORDS = mapOf(
            1 to Pair(250, 1000),
            2 to Pair(650, 1000),
            3 to Pair(250, 1100),
            4 to Pair(650, 1100),
        )
        private val SWAP_COORDS = mapOf(
            1 to Pair(1000, 1000),
            2 to Pair(1300, 1000),
            3 to Pair(1600, 1000),
        )
    }

    private val scope = CoroutineScope(Dispatchers.IO + SupervisorJob())

    /**
     * 执行服务器返回的动作。
     *
     * 动作类型：
     * - skill: 点击技能按钮（skill_index 1-4）
     * - swap: 点击换宠按钮（swap_index 1-3）
     * - tap: 点击指定坐标（coordinate [x, y]）
     * - wait: 等待（不点击）
     */
    fun execute(action: JSONObject) {
        val actionType = action.optString("action_type", "wait")
        val delayMs = action.optInt("delay_ms", 500)
        val skillIndex = action.optInt("skill_index", -1).takeIf { it > 0 }
        val swapIndex = action.optInt("swap_index", -1).takeIf { it > 0 }
        val coordJson = action.optJSONArray("coordinate")
        val reasoning = action.optString("reasoning", "")

        Log.d(TAG, "执行: $actionType (index=$skillIndex, coord=$coordJson) delay=${delayMs}ms")
        Log.d(TAG, "理由: $reasoning")

        scope.launch {
            // 等待指定延迟
            if (delayMs > 0) delay(delayMs.toLong())

            var success = true

            // 执行点击
            when (actionType) {
                "skill" -> {
                    val coord = skillIndex?.let { SKILL_COORDS[it] }
                    if (coord != null) {
                        success = CaptureService.performTap(coord.first, coord.second)
                    }
                }
                "swap" -> {
                    val coord = swapIndex?.let { SWAP_COORDS[it] }
                    if (coord != null) {
                        success = CaptureService.performTap(coord.first, coord.second)
                    } else {
                        // 默认换宠位置
                        success = CaptureService.performTap(1000, 1000)
                    }
                }
                "tap" -> {
                    if (coordJson != null && coordJson.length() >= 2) {
                        val x = coordJson.getInt(0)
                        val y = coordJson.getInt(1)
                        success = CaptureService.performTap(x, y)
                    }
                }
                "wait" -> {
                    // 只等待，不点击
                }
            }

            // 上报执行结果
            wsClient.sendActionResult(success)
        }
    }
}