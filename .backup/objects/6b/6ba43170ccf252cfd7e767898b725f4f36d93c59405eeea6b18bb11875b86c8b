package com.luoking.agent

import android.content.Intent
import android.media.projection.MediaProjectionManager
import android.os.Build
import android.os.Bundle
import android.provider.Settings
import android.widget.Button
import android.widget.TextView
import android.widget.Toast
import androidx.activity.result.contract.ActivityResultContracts
import androidx.appcompat.app.AlertDialog
import androidx.appcompat.app.AppCompatActivity
import com.luoking.agent.models.SessionState

/**
 * 主界面——一键启动，无废话。
 *
 * 设计原则：
 * - 首次：装机 → 授权无障碍 → 授权截屏 → 保存地址
 * - 以后每次：打开 APK → 点「🚀 一键连接并开始」→ 自动跑
 *
 * 按钮行为：
 *   - 首次点击：检查权限 → 缺啥弹啥 → 授权后自动连接
 *   - 后续点击：直接连接（权限已保存）
 *   - 再次点击：停止
 */
class MainActivity : AppCompatActivity() {

    private lateinit var statusText: TextView
    private lateinit var connectBtn: Button
    private lateinit var serverAddressInput: android.widget.EditText
    private lateinit var statsText: TextView
    private lateinit var permissionText: TextView

    private var wsClient: WebSocketClient? = null
    private var actionDispatcher: ActionDispatcher? = null
    private var isRunning = false

    private val screenCaptureLauncher = registerForActivityResult(
        ActivityResultContracts.StartActivityForResult()
    ) { result ->
        if (result.resultCode == RESULT_OK && result.data != null) {
            // 授权成功，截图服务 + WebSocket 全自动启动
            startScreenCaptureService(result.resultCode, result.data!!)
        } else {
            Toast.makeText(this, "需要屏幕捕获权限才能运行", Toast.LENGTH_SHORT).show()
        }
    }

    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        try {
            setContentView(R.layout.activity_main)

            statusText = findViewById(R.id.status_text)
            connectBtn = findViewById(R.id.connect_btn)
            serverAddressInput = findViewById(R.id.server_address)
            statsText = findViewById(R.id.stats_text)
            permissionText = findViewById(R.id.permission_text)

            // 恢复上次保存的服务器地址
            val prefs = getSharedPreferences("luo_king", MODE_PRIVATE)
            serverAddressInput.setText(prefs.getString("server_url", "ws://193.112.187.72:8765"))

            // 生成设备 ID
            SessionState.deviceId = "phone_${android.provider.Settings.Secure.getString(
                contentResolver, Settings.Secure.ANDROID_ID
            )?.takeLast(6) ?: "unknown"}"

            // 一键按钮
            connectBtn.setOnClickListener {
                if (isRunning) {
                    stopAll()
                } else {
                    startOneClick()
                }
            }

            updateStatus()
            updatePermissionStatus()
        } catch (e: Exception) {
            Log.e("MainActivity", "onCreate崩溃", e)
            android.widget.Toast.makeText(this, "启动失败: ${e.message}", Toast.LENGTH_LONG).show()
        }
    }

    override fun onResume() {
        super.onResume()
        updateStatus()
        updatePermissionStatus()
    }

    // ──────────────────────────────────────────────────────────────
    // 一键流程
    // ──────────────────────────────────────────────────────────────

    /**
     * 一键连接并开始。
     *
     * 自动检查权限链条：
     *   ① 服务器地址是否填写
     *   ② 无障碍是否开启 → 否：弹窗引导
     *   ③ 无障碍已开启 → 直接拉起截屏授权
     *   ④ 截屏授权成功 → 自动启动截图 + WebSocket
     */
    private fun startOneClick() {
        // ① 服务器地址
        val serverUrl = serverAddressInput.text.toString().trim()
        if (serverUrl.isEmpty()) {
            Toast.makeText(this, "请输入服务器地址", Toast.LENGTH_SHORT).show()
            return
        }
        SessionState.serverUrl = serverUrl
        getSharedPreferences("luo_king", MODE_PRIVATE).edit()
            .putString("server_url", serverUrl).apply()

        // ② 无障碍权限检查
        if (!isAccessibilityServiceEnabled()) {
            AlertDialog.Builder(this)
                .setTitle("需要无障碍权限")
                .setMessage("点击「去设置」→ 找到「洛克王国AI助手」→ 开启无障碍开关\n\n开启后返回此界面，再次点击按钮即可启动。")
                .setPositiveButton("去设置") { _, _ ->
                    startActivity(Intent(Settings.ACTION_ACCESSIBILITY_SETTINGS))
                }
                .setNegativeButton("取消", null)
                .show()
            return
        }

        // ③ 截屏授权（自动拉起系统弹窗）
        requestScreenCapture()
    }

    // ── 权限检查 ──

    private fun requestScreenCapture() {
        val projectionManager = getSystemService(MEDIA_PROJECTION_SERVICE)
                as MediaProjectionManager
        screenCaptureLauncher.launch(projectionManager.createScreenCaptureIntent())
    }

    private fun isAccessibilityServiceEnabled(): Boolean {
        val service = "${packageName}/${AccessibilityInputService::class.java.canonicalName}"
        try {
            val enabledServices = Settings.Secure.getString(
                contentResolver,
                Settings.Secure.ENABLED_ACCESSIBILITY_SERVICES
            ) ?: return false
            return enabledServices.split(":").any { it.equals(service, ignoreCase = true) }
        } catch (e: Exception) {
            return false
        }
    }

    private fun updatePermissionStatus() {
        val acc = if (isAccessibilityServiceEnabled()) "✅" else "❌"
        permissionText.text = "权限状态：无障碍 $acc  |  截屏：关联按钮触发"
    }

    // ── 启动服务（截屏授权成功后自动调用） ──

    private fun startScreenCaptureService(resultCode: Int, data: Intent) {
        // 启动截图前台服务
        val intent = Intent(this, ScreenCaptureService::class.java).apply {
            putExtra("result_code", resultCode)
            putExtra("data", data)
        }
        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.O) {
            startForegroundService(intent)
        } else {
            startService(intent)
        }
        // 截图服务启动后立即连接 WebSocket
        startWebSocket()
    }

    private fun startWebSocket() {
        isRunning = true
        connectBtn.text = "⏹ 停止运行"
        statusText.text = "🔄 连接服务器..."
        updatePermissionStatus()

        wsClient = WebSocketClient(
            serverUrl = SessionState.serverUrl,
            onAction = { action -> actionDispatcher?.execute(action) },
            onConnected = {
                runOnUiThread { statusText.text = "🔄 等待 session_id..." }
            },
            onSessionEstablished = {
                runOnUiThread {
                    statusText.text = "🟢 运行中"
                    startScreenshotLoop()
                }
            },
            onDisconnected = {
                runOnUiThread {
                    statusText.text = "🔴 已断开"
                    stopScreenshotLoop()
                    updateStatus()
                }
            }
        )

        actionDispatcher = ActionDispatcher(wsClient!!)
        wsClient?.connect()
    }

    // ── 截图循环 ──

    private val mainHandler = android.os.Handler(mainLooper)
    private val screenshotRunnable = object : Runnable {
        override fun run() {
            if (isRunning) {
                ScreenCaptureService.requestScreenshot()
                mainHandler.postDelayed(this, SessionState.screenshotIntervalMs)
                updateStatus()
            }
        }
    }

    private fun startScreenshotLoop() {
        mainHandler.removeCallbacks(screenshotRunnable)
        mainHandler.post(screenshotRunnable)
    }

    private fun stopScreenshotLoop() {
        mainHandler.removeCallbacks(screenshotRunnable)
    }

    private fun stopAll() {
        isRunning = false
        stopScreenshotLoop()
        wsClient?.disconnect()
        stopService(Intent(this, ScreenCaptureService::class.java))
        connectBtn.text = "🚀 一键连接并开始"
        statusText.text = "⏸ 已停止"
        SessionState.isRunning = false
        SessionState.sessionId = ""
    }

    // ── 状态更新 ──

    private fun updateStatus() {
        val status = StringBuilder()
        status.append("📱 ${SessionState.deviceId}\n")
        status.append(if (wsClient?.isSessionEstablished() == true) "🟢 会话已建立" else "🔴 未连接")
        status.append(" | 阶段: ${SessionState.phase}\n")
        if (SessionState.sessionId.isNotEmpty()) {
            status.append("🆔 ${SessionState.sessionId.takeLast(8)}\n")
        }
        status.append("📸 ${SessionState.totalScreenshots}  |  🎯 ${SessionState.totalActions}")
        statsText.text = status.toString()
    }
}