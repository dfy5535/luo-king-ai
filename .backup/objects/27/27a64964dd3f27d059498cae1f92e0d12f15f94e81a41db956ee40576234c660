"""
luo_king_agent/engine/battle_engine.py
========================================
Operator的要求：
  "真正的大脑不是Prompt。"
  "真正的大脑应该叫Battle Engine。"
  "它里面不是Prompt，而是：当前状态 → 查数据库 → 计算属性克制 → 计算速度 → 计算Buff → 预测敌人 → 最后 → 问AI"

这个Battle Engine负责所有"确定性"的计算。
AI只负责"博弈"，不负责"算数"。
"""

from __future__ import annotations
from typing import List, Dict, Optional, Tuple, Any
from dataclasses import dataclass, field
import logging
import math

from ..core.models import (
    BattleState, PetState, SkillState, BattleAction, BattleActionType,
    PetType, BuffType, WeatherType, StatusCondition,
    get_type_effectiveness, TYPE_CHART
)

logger = logging.getLogger(__name__)


@dataclass
class SkillScore:
    """技能评分 - Battle Engine给AI的建议"""
    skill_name: str
    score: float          # 0-100, 综合评分
    damage_estimate: float  # 预估伤害
    type_effectiveness: float  # 属性克制倍率
    is_recommended: bool  # 引擎推荐
    reasoning: str = ""   # 评分理由（简短）


@dataclass
class BattleRecommendation:
    """战斗推荐 - Battle Engine的输出，AI的输入"""
    # 技能推荐（按评分排序）
    skill_scores: List[SkillScore] = field(default_factory=list)
    
    # 换宠推荐
    swap_recommendations: List[Tuple[str, float]] = field(default_factory=list)
    
    # 局势评估
    advantage: float = 0.0    # -1.0 ~ 1.0, 我方优势
    urgency: str = "normal"   # "safe" / "normal" / "dangerous" / "critical"
    
    # 敌方预测
    predicted_enemy_action: Optional[str] = None
    risk_warning: Optional[str] = None
    
    # 直接建议（如果引擎足够确定）
    suggested_action: Optional[BattleAction] = None
    
    def to_prompt_context(self) -> str:
        """压缩成AI能理解的建议文本"""
        lines = []
        lines.append("【战斗引擎分析】")
        lines.append(f"局势评估: {self.advantage:.2f} ({self.urgency})")
        
        if self.skill_scores:
            lines.append("\n技能评分:")
            for s in sorted(self.skill_scores, key=lambda x: x.score, reverse=True):
                rec = " ★推荐" if s.is_recommended else ""
                lines.append(f"  {s.skill_name}: {s.score:.0f}/100 (伤害预估:{s.damage_estimate:.0f} 克制:{s.type_effectiveness:.1f}x){rec}")
                if s.reasoning:
                    lines.append(f"    理由: {s.reasoning}")
        
        if self.swap_recommendations:
            lines.append("\n换宠建议:")
            for name, score in self.swap_recommendations:
                lines.append(f"  {name}: {score:.0f}/100")
        
        if self.predicted_enemy_action:
            lines.append(f"\n敌方预测: {self.predicted_enemy_action}")
        
        if self.risk_warning:
            lines.append(f"\n⚠️ 风险提示: {self.risk_warning}")
        
        return "\n".join(lines)


class BattleEngine:
    """
    战斗引擎 - 整个系统的"真正大脑"。
    
    职责清单：
    ✓ 计算属性克制（不需要AI）
    ✓ 计算速度排序（不需要AI）
    ✓ 计算Buff影响（不需要AI）
    ✓ 计算伤害预估（不需要AI）
    ✓ 技能PP管理（不需要AI）
    ✓ 局势评估（不需要AI）
    ✓ 敌方行为预测（部分需要AI）
    ✓ 博弈决策（交给AI）
    
    使用方式：
        engine = BattleEngine()
        engine.update_state(battle_state)
        recommendation = engine.analyze()
        # 然后把recommendation给LLM做最终决策
    """
    
    # 能力等级倍率表（+1 = 1.5x, -1 = 0.67x, 宝可梦/洛克通用）
    BUFF_MULTIPLIERS = {
        -6: 0.25, -5: 0.29, -4: 0.33, -3: 0.40, -2: 0.50, -1: 0.67,
        0: 1.0,
        +1: 1.5, +2: 2.0, +3: 2.5, +4: 3.0, +5: 3.5, +6: 4.0,
    }
    
    def __init__(self):
        self.state: Optional[BattleState] = None
        self.last_recommendation: Optional[BattleRecommendation] = None
        
        # 知识库（可从数据库加载）
        self.pet_database: Dict[str, Dict] = {}   # 宠物基础数据
        self.skill_database: Dict[str, Dict] = {} # 技能基础数据
        
    def update_state(self, state: BattleState):
        """更新战斗状态"""
        self.state = state
    
    # ──────────────────────────────────────────────────────────────
    # 核心分析管道
    # ──────────────────────────────────────────────────────────────
    
    def analyze(self) -> BattleRecommendation:
        """
        完整分析管道。
        这是Battle Engine的入口，也是LLM的"预处理"。
        """
        if not self.state or not self.state.is_my_turn:
            return BattleRecommendation()
        
        rec = BattleRecommendation()
        
        # 1. 技能评分
        rec.skill_scores = self._score_skills()
        
        # 2. 换宠推荐
        rec.swap_recommendations = self._evaluate_swaps()
        
        # 3. 局势评估
        rec.advantage, rec.urgency = self._evaluate_situation()
        
        # 4. 敌方预测
        rec.predicted_enemy_action = self._predict_enemy_action()
        
        # 5. 风险检测
        rec.risk_warning = self._detect_risks()
        
        # 6. 如果引擎足够确定，直接给出建议
        if self._can_decide_without_llm(rec):
            rec.suggested_action = self._deterministic_decision(rec)
        
        self.last_recommendation = rec
        return rec
    
    # ──────────────────────────────────────────────────────────────
    # 1. 技能评分 - 不需要AI
    # ──────────────────────────────────────────────────────────────
    
    def _score_skills(self) -> List[SkillScore]:
        """对每个可用技能评分"""
        if not self.state or not self.state.my_active or not self.state.enemy_pet:
            return []
        
        my_pet = self.state.my_active
        enemy = self.state.enemy_pet
        scores = []
        
        for skill in my_pet.skills:
            if skill.pp_current <= 0 or skill.is_sealed:
                continue
            
            score = 0.0
            reasons = []
            
            # 1. 属性克制
            attack_type = skill.skill_type.value
            defend_types = [t.value for t in enemy.types]
            effectiveness = get_type_effectiveness(attack_type, defend_types)
            
            type_score = effectiveness * 50  # 克制2x → 100分, 1x → 50分, 0.5x → 25分
            if effectiveness == 0:
                type_score = -100
                reasons.append(f"{skill.skill_type.value} 对 {enemy.name} 无效!")
            elif effectiveness >= 2:
                reasons.append(f"属性克制! ({effectiveness}x)")
            elif effectiveness <= 0.5:
                reasons.append(f"被抵抗 ({effectiveness}x)")
            
            score += type_score
            
            # 2. 威力基础
            if skill.power > 0:
                power_score = min(skill.power / 1.5, 40)  # 120威力≈80分
                score += power_score
            else:
                # 变化技能（无威力）
                score += 15  # 基础分
            
            # 3. PP管理
            pp_ratio = skill.pp_current / skill.pp_max if skill.pp_max > 0 else 0
            if pp_ratio <= 0.25:
                score -= 20  # PP快没了，节约使用
                reasons.append(f"PP不足 ({skill.pp_current}/{skill.pp_max})")
            elif pp_ratio >= 0.75:
                score += 5  # PP充足
            
            # 4. 先手度
            if skill.priority > 0:
                score += 10
                reasons.append(f"先手技能 (priority {skill.priority})")
            
            # 5. 伤害预估
            damage = self._estimate_damage(skill, my_pet, enemy, effectiveness)
            
            # 6. 斩杀线检测
            if damage >= enemy.hp_current:
                score += 30  # 斩杀线，大幅加分
                reasons.append(f"斩杀线! (预估伤害 {damage:.0f} ≥ {enemy.hp_current})")
            
            is_rec = score >= 70
            scores.append(SkillScore(
                skill_name=skill.name,
                score=max(0, min(100, score)),
                damage_estimate=damage,
                type_effectiveness=effectiveness,
                is_recommended=is_rec,
                reasoning="; ".join(reasons) if reasons else ""
            ))
        
        return sorted(scores, key=lambda x: x.score, reverse=True)
    
    def _estimate_damage(self, skill: SkillState, attacker: PetState, 
                         defender: PetState, effectiveness: float) -> float:
        """
        简化伤害预估。
        不需要精确，只需要"相对大小"即可。
        """
        if skill.power == 0:
            return 0.0  # 变化技能
        
        # 基础伤害 = 威力 * 攻击力 / 防御力 * 克制倍率
        base_atk = 100  # 简化，实际应从数据库读取
        base_def = 100
        
        # Buff影响
        atk_buff = attacker.buffs.get(BuffType.攻击, 0) or attacker.buffs.get(BuffType.魔攻, 0)
        def_buff = defender.buffs.get(BuffType.防御, 0) or defender.buffs.get(BuffType.魔抗, 0)
        
        atk_mult = self.BUFF_MULTIPLIERS.get(atk_buff, 1.0)
        def_mult = self.BUFF_MULTIPLIERS.get(def_buff, 1.0)
        
        # 天气影响
        weather_mult = 1.0
        if self.state:
            if self.state.weather == WeatherType.晴天 and skill.skill_type == PetType.火:
                weather_mult = 1.5
            elif self.state.weather == WeatherType.雨天 and skill.skill_type == PetType.水:
                weather_mult = 1.5
            elif self.state.weather == WeatherType.雨天 and skill.skill_type == PetType.火:
                weather_mult = 0.5
        
        # 随机因素 (0.85 ~ 1.0)
        random_factor = 0.925
        
        damage = (skill.power * base_atk * atk_mult / (base_def * def_mult) 
                  * effectiveness * weather_mult * random_factor)
        
        return max(0, damage)
    
    # ──────────────────────────────────────────────────────────────
    # 2. 换宠评估 - 不需要AI
    # ──────────────────────────────────────────────────────────────
    
    def _evaluate_swaps(self) -> List[Tuple[str, float]]:
        """评估换宠选项"""
        if not self.state or not self.state.enemy_pet:
            return []
        
        enemy = self.state.enemy_pet
        swaps = []
        
        for pet in self.state.my_pets:
            if pet == self.state.my_active or not pet.is_alive:
                continue
            
            score = 50.0
            
            # 属性抗性：如果这只宠物抗敌方属性
            for t in pet.types:
                for et in enemy.types:
                    # 攻击方×防御方
                    eff = get_type_effectiveness(et.value, [t.value])
                    if eff <= 0.5:
                        score += 15
                    elif eff >= 2:
                        score -= 20
            
            # HP越高越好
            score += pet.hp_percent * 15
            
            swaps.append((pet.name, max(0, min(100, score))))
        
        return sorted(swaps, key=lambda x: x[1], reverse=True)
    
    # ──────────────────────────────────────────────────────────────
    # 3. 局势评估 - 不需要AI
    # ──────────────────────────────────────────────────────────────
    
    def _evaluate_situation(self) -> Tuple[float, str]:
        """
        评估局势。
        Returns:
            advantage: -1.0 ~ 1.0
            urgency: "safe" / "normal" / "dangerous" / "critical"
        """
        if not self.state or not self.state.my_active or not self.state.enemy_pet:
            return 0.0, "normal"
        
        my = self.state.my_active
        enemy = self.state.enemy_pet
        
        # HP对比
        hp_advantage = my.hp_percent - enemy.hp_percent
        
        # 存活宠物数量
        my_alive = sum(1 for p in self.state.my_pets if p.is_alive)
        enemy_alive = len(self.state.enemy_pets_known) if self.state.enemy_pets_known else 1
        
        # 属性优势
        type_advantage = 0.0
        for t in my.types:
            eff = get_type_effectiveness(t.value, [e.value for e in enemy.types])
            if eff >= 2:
                type_advantage += 0.2
            elif eff <= 0.5:
                type_advantage -= 0.2
        
        advantage = hp_advantage * 0.5 + (my_alive - enemy_alive) * 0.15 + type_advantage
        
        # 确定紧急程度
        if my.hp_percent <= 0.2:
            urgency = "critical"
        elif my.hp_percent <= 0.4:
            urgency = "dangerous"
        elif my.hp_percent >= 0.8 and enemy.hp_percent <= 0.3:
            urgency = "safe"
        else:
            urgency = "normal"
        
        return max(-1.0, min(1.0, advantage)), urgency
    
    # ──────────────────────────────────────────────────────────────
    # 4. 敌方预测 - 交给AI，但引擎可以做基础分析
    # ──────────────────────────────────────────────────────────────
    
    def _predict_enemy_action(self) -> Optional[str]:
        """基础敌方预测（浅层，深层交给AI）"""
        if not self.state or not self.state.enemy_pet:
            return None
        
        enemy = self.state.enemy_pet
        
        # 如果敌方HP很低，大概率会换宠
        if enemy.hp_percent <= 0.3 and len(self.state.enemy_pets_known) > 1:
            return "可能换宠治疗"
        
        # 如果敌方有异常状态，可能尝试解状态
        if enemy.status != StatusCondition.无:
            return "可能尝试解除异常状态"
        
        return None
    
    # ──────────────────────────────────────────────────────────────
    # 5. 风险检测 - 不需要AI
    # ──────────────────────────────────────────────────────────────
    
    def _detect_risks(self) -> Optional[str]:
        """检测风险"""
        if not self.state or not self.state.my_active:
            return None
        
        my = self.state.my_active
        risks = []
        
        # 低HP风险
        if my.hp_percent <= 0.25:
            risks.append(f"HP过低 ({my.hp_percent:.0%})，建议换宠或治疗")
        
        # 异常状态风险
        if my.status != StatusCondition.无:
            risks.append(f"处于{my.status.value}状态")
        
        # PP耗尽风险
        skills_with_pp = [s for s in my.skills if s.pp_current > 0 and not s.is_sealed]
        if len(skills_with_pp) <= 1:
            risks.append("技能PP即将耗尽")
        
        return "; ".join(risks) if risks else None
    
    # ──────────────────────────────────────────────────────────────
    # 6. 确定性决策 - 某些情况不需要AI
    # ──────────────────────────────────────────────────────────────
    
    def _can_decide_without_llm(self, rec: BattleRecommendation) -> bool:
        """
        判断是否可以不经过LLM直接决策。
        条件：
        - 只有一个技能可用（没得选）
        - 斩杀线且属性克制（闭眼打）
        - 局势极度危险，需要立即换宠
        """
        # 只有一个可用技能
        usable = [s for s in rec.skill_scores if s.score > 0]
        if len(usable) == 1 and usable[0].score >= 80:
            return True
        
        # 斩杀线 + 属性克制
        best = rec.skill_scores[0] if rec.skill_scores else None
        if best and best.type_effectiveness >= 2 and best.damage_estimate > 0:
            return True
        
        return False
    
    def _deterministic_decision(self, rec: BattleRecommendation) -> BattleAction:
        """确定性决策"""
        if rec.skill_scores:
            best = rec.skill_scores[0]
            return BattleAction(
                action_type=BattleActionType.技能,
                target=best.skill_name,
                confidence=0.95,
                reasoning=f"引擎确定性决策: {best.reasoning}"
            )
        return BattleAction(
            action_type=BattleActionType.等待,
            confidence=0.0,
            reasoning="无可行动作"
        )


# ──────────────────────────────────────────────────────────────
# 知识库（游戏数据库）
# ──────────────────────────────────────────────────────────────

class PetDatabase:
    """
    宠物知识库。
    不是RAG，不是PDF，不是Markdown。
    而是真正的结构化数据。
    AI根本不用背，查数据库即可。
    """
    
    def __init__(self):
        self.pets: Dict[str, Dict] = {}
        self.skills: Dict[str, Dict] = {}
        self._load_base_data()
    
    def _load_base_data(self):
        """加载基础数据（可从JSON/DB加载）"""
        # 示例数据
        self.pets["烈火战神"] = {
            "types": ["fire"],
            "base_stats": {"hp": 120, "attack": 110, "defense": 90, "sp_attack": 95, "sp_defense": 85, "speed": 100},
            "learnable_skills": ["烈焰冲锋", "火焰护盾", "速度强化", "热力爆燃"]
        }
        self.pets["冰龙王"] = {
            "types": ["ice", "dragon"],
            "base_stats": {"hp": 130, "attack": 80, "defense": 85, "sp_attack": 120, "sp_defense": 95, "speed": 80},
            "learnable_skills": ["冰霜吐息", "龙之舞", "冰冻之风", "绝对零度"]
        }
        self.pets["圣光迪莫"] = {
            "types": ["light"],
            "base_stats": {"hp": 100, "attack": 100, "defense": 100, "sp_attack": 100, "sp_defense": 100, "speed": 100},
            "learnable_skills": ["光之刃", "神圣护盾", "光速闪避", "审判之光"]
        }
    
    def get_pet(self, name: str) -> Optional[Dict]:
        return self.pets.get(name)
    
    def get_skill(self, name: str) -> Optional[Dict]:
        return self.skills.get(name)
    
    def get_type_weaknesses(self, types: List[str]) -> List[Tuple[str, float]]:
        """查询属性弱点"""
        weaknesses = []
        for attack_type in TYPE_CHART:
            eff = get_type_effectiveness(attack_type, types)
            if eff > 1:
                weaknesses.append((attack_type, eff))
        return sorted(weaknesses, key=lambda x: x[1], reverse=True)