"""
测试网关 - 最小 WebSocket 服务器
唯一职责：验证 APK 的 heartbeat→upload→action→action_result 闭环
不依赖任何 AI 模块
"""
import asyncio
import json
import uuid
import logging

logging.basicConfig(level=logging.DEBUG,
                    format="%(asctime)s [%(levelname)s] %(message)s")
log = logging.getLogger("test_gateway")

sessions = {}  # device_id -> session_id
total_uploads = 0
total_actions = 0


async def handle_heartbeat(ws, data):
    device_id = data.get("device_id", "unknown")
    sid = uuid.uuid4().hex[:12]
    sessions[device_id] = sid
    log.info(f"[heartbeat] device={device_id} session={sid}")
    await ws.send(json.dumps({
        "type": "heartbeat_ack",
        "session_id": sid
    }))


async def handle_upload(ws, data):
    global total_uploads, total_actions
    device_id = data.get("device_id", "unknown")
    sid = data.get("session_id", "")
    expected = sessions.get(device_id)
    if not expected or sid != expected:
        log.warning(f"[upload] bad session: device={device_id} got={sid} expected={expected}")
        await ws.send(json.dumps({
            "type": "error",
            "message": "invalid session_id"
        }))
        return
    total_uploads += 1
    img_len = len(data.get("image", ""))
    log.info(f"[upload] #{total_uploads} device={device_id} image_size={img_len}B")

    # 返回固定 tap 动作 —— 点击屏幕中心
    total_actions += 1
    await ws.send(json.dumps({
        "type": "action",
        "action_type": "tap",
        "coordinate": [540, 960],
        "delay_ms": 500,
        "session_id": sid
    }))


async def handle_action_result(ws, data):
    device_id = data.get("device_id", "unknown")
    success = data.get("success", False)
    log.info(f"[action_result] device={device_id} success={success}")


async def handler(ws):
    log.info(f"[connection] new client from {ws.remote_address}")
    try:
        async for message in ws:
            try:
                data = json.loads(message)
                msg_type = data.get("type", "")
                if msg_type == "heartbeat":
                    await handle_heartbeat(ws, data)
                elif msg_type == "upload":
                    await handle_upload(ws, data)
                elif msg_type == "action_result":
                    await handle_action_result(ws, data)
                else:
                    log.warning(f"[unknown] type={msg_type}")
            except json.JSONDecodeError as e:
                log.error(f"[bad_json] {e}")
    except Exception as e:
        log.error(f"[error] {e}")
    finally:
        log.info(f"[disconnect] {ws.remote_address}")


async def main():
    log.info("🧪 测试模式服务器启动: ws://0.0.0.0:8765")
    log.info("    收到 upload 后返回固定 tap 动作，不依赖任何 AI")
    log.info("    按 Ctrl+C 停止")
    async with asyncio.wait_for(
        asyncio.start_server, timeout=5
    ):
        pass
    
    # 正确的启动方式
    loop = asyncio.get_running_loop()
    stop = loop.create_future()
    
    async with asyncio.start_server(
        handler,
        "0.0.0.0",
        8765
    ):
        # Oops, that's for TCP, need websockets...
        pass

    # 正确：使用 websockets 库
    import websockets
    async with websockets.serve(
        handler,
        "0.0.0.0",
        8765
    ):
        log.info(f"server listening on 0.0.0.0:8765")
        await asyncio.Future()  # run forever


if __name__ == "__main__":
    asyncio.run(main())