package com.luoking.agent

import android.util.Log
import com.luoking.agent.models.SessionState
import kotlinx.coroutines.*
import org.json.JSONObject

/**
 * 动作调度器 - 只把服务器动作映射到具体手势
 *
 * 职责单一：
 * 1. 解析服务器返回的 JSON 动作
 * 2. 调用 AccessibilityInputService 执行对应手势
 * 3. 上报执行结果
 *
 * 不参与截图，不参与网络，不参与决策。
 */
class ActionDispatcher(
    private val wsClient: WebSocketClient
) {
    companion object {
        private const val TAG = "ActionDispatcher"
    }

    private val scope = CoroutineScope(Dispatchers.IO + SupervisorJob())

    /**
     * 执行服务器返回的动作。
     *
     * 动作类型映射：
     * - "skill" → 点击技能按钮（skill_index 1-4）
     * - "swap"  → 点击换宠按钮（swap_index 1-3）
     * - "tap"   → 点击指定坐标
     * - "back"  → 返回键
     * - "wait"  → 只等待，不点击
     */
    fun execute(action: JSONObject) {
        val actionType = action.optString("action_type", "wait")
        val delayMs = action.optInt("delay_ms", 500).toLong()
        val skillIndex = action.optInt("skill_index", -1).takeIf { it > 0 }
        val swapIndex = action.optInt("swap_index", -1).takeIf { it > 0 }
        val coordJson = action.optJSONArray("coordinate")
        val reasoning = action.optString("reasoning", "")

        Log.d(TAG, "执行: $actionType (index=$skillIndex, coord=$coordJson) delay=${delayMs}ms")

        scope.launch {
            // 先等待指定延迟
            if (delayMs > 0) delay(delayMs)

            var success = true

            when (actionType) {
                "skill" -> {
                    val coord = skillIndex?.let { SessionState.getSkillCoord(it) }
                    if (coord != null) {
                        success = AccessibilityInputService.tap(coord.first, coord.second)
                    }
                }
                "swap" -> {
                    val coord = swapIndex?.let { SessionState.getSwapCoord(it) }
                    if (coord != null) {
                        success = AccessibilityInputService.tap(coord.first, coord.second)
                    } else {
                        success = AccessibilityInputService.tap(1000, 1000)
                    }
                }
                "tap" -> {
                    if (coordJson != null && coordJson.length() >= 2) {
                        success = AccessibilityInputService.tap(
                            coordJson.getInt(0), coordJson.getInt(1)
                        )
                    }
                }
                "back" -> {
                    success = AccessibilityInputService.back()
                }
                "wait" -> {
                    // 只等待，不点击
                }
            }

            // 等待动画
            if (success) delay(200)

            // 上报执行结果
            wsClient.sendActionResult(success)
        }
    }
}