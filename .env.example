# luo_king_agent 环境变量配置
# 复制此文件为 .env 并填入你的密钥

# SenseNova API（用于视觉解析：截图→BattleState）
SENSENOVA_API_KEY=sk-your_key_here
SENSENOVA_VISION_MODEL=sensenova-6.7-flash-lite

# 策略LLM（用于博弈决策，可复用SenseNova或改用其他）
STRATEGY_API_KEY=your_key_here
STRATEGY_BASE_URL=https://token.sensenova.cn/v1
STRATEGY_MODEL=gemini-2.5-flash

# 设备连接
DEVICE_BACKEND=adb
DEVICE_HOST=192.168.1.xxx
DEVICE_PORT=5555

# 数据存储
DATA_DIR=data/battles
MEMORY_DIR=data/memory